{
  "Logging": { "LogLevel": { "Default": "Information" } },
  "ReverseProxy": {
    "Routes": [
        {
          "RouteId": "patient-route",
          "ClusterId": "patient-cluster",
          "Match": { "Path": "/api/patient/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/patient" }]
        },
        {
          "RouteId": "encounter-route",
          "ClusterId": "encounter-cluster",
          "Match": { "Path": "/api/encounter/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/encounter" }]
        },
        {
          "RouteId": "inpatient-route",
          "ClusterId": "inpatient-cluster",
          "Match": { "Path": "/api/inpatient/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/inpatient" }]
        },
        {
          "RouteId": "emergency-route",
          "ClusterId": "emergency-cluster",
          "Match": { "Path": "/api/emergency/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/emergency" }]
        },
        {
          "RouteId": "diagnostics-route",
          "ClusterId": "diagnostics-cluster",
          "Match": { "Path": "/api/diagnostics/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/diagnostics" }]
        },
        {
          "RouteId": "revenue-route",
          "ClusterId": "revenue-cluster",
          "Match": { "Path": "/api/revenue/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/revenue" }]
        },
        {
          "RouteId": "audit-route",
          "ClusterId": "audit-cluster",
          "Match": { "Path": "/api/audit/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/audit" }]
        },
        {
          "RouteId": "ai-route",
          "ClusterId": "ai-cluster",
          "Match": { "Path": "/api/ai/{**catch-all}" },
          "Transforms": [{ "PathRemovePrefix": "/api/ai" }]
        }
    ],
    "Clusters": {
        "patient-cluster": {
          "Destinations": {
            "default": { "Address": "http://patient-api:8080" }
          }
        },
        "encounter-cluster": {
          "Destinations": {
            "default": { "Address": "http://encounter-api:8080" }
          }
        },
        "inpatient-cluster": {
          "Destinations": {
            "default": { "Address": "http://inpatient-api:8080" }
          }
        },
        "emergency-cluster": {
          "Destinations": {
            "default": { "Address": "http://emergency-api:8080" }
          }
        },
        "diagnostics-cluster": {
          "Destinations": {
            "default": { "Address": "http://diagnostics-api:8080" }
          }
        },
        "revenue-cluster": {
          "Destinations": {
            "default": { "Address": "http://revenue-api:8080" }
          }
        },
        "audit-cluster": {
          "Destinations": {
            "default": { "Address": "http://audit-api:8080" }
          }
        },
        "ai-cluster": {
          "Destinations": {
            "default": { "Address": "http://ai-api:8080" }
          }
        }
    }
  }
}