@page
@model GNex.Studio.Pages.Emergency.EmergencyBoardModel
@{ ViewData["Title"] = "EmergencyBoard"; }

<div class="container-fluid">
    <h2 class="mb-3">EmergencyBoard</h2>
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Emergency &mdash; EmergencyArrival</span>
            <form method="get" class="d-flex gap-2">
                <input type="text" name="search" value="@Model.View.SearchTerm"
                       class="form-control form-control-sm" placeholder="Search..." />
                <button class="btn btn-sm btn-primary">Go</button>
            </form>
        </div>
        <div class="card-body">
            <table class="table table-hover table-sm">
                <thead>
                    <tr><th>ID</th><th>Name</th><th>Status</th><th>Facility</th><th>Updated</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.View.Items)
                    {
                        <tr>
                            <td>@item.Id[..8]</td>
                            <td>@item.DisplayName</td>
                            <td><span class="badge bg-info">@item.Status</span></td>
                            <td>@item.Facility</td>
                            <td>@item.LastUpdated.ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.View.Items.Any())
            {
                <p class="text-muted text-center">No records yet. Service layer will be wired during implementation.</p>
            }
        </div>
    </div>
</div>