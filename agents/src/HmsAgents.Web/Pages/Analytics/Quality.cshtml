@page
@{
    ViewData["Title"] = "Quality Analytics";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-shield-check me-2"></i>Quality Analytics</h2>
        <select class="form-select d-inline-block" style="width:auto" id="projectFilter" onchange="load()"><option value="">All Projects</option></select>
    </div>

    <!-- Summary -->
    <div class="row mb-4">
        <div class="col-md-2"><div class="card text-bg-success"><div class="card-body py-2 text-center"><h6 class="mb-0">Code Quality</h6><h3 id="codeQuality">A</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Test Coverage</h6><h3 id="testCoverage">0%</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Requirements Coverage</h6><h3 id="reqCoverage">0%</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Security Score</h6><h3 id="secScore">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Open Issues</h6><h3 id="openIssues">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Tech Debt</h6><h3 id="techDebt">0h</h3></div></div></div>
    </div>

    <div class="row">
        <!-- Quality Gates Status -->
        <div class="col-md-6">
            <div class="card"><div class="card-header"><h6 class="mb-0">Quality Gate Status by Project</h6></div>
            <div class="card-body p-0"><table class="table table-hover mb-0">
                <thead><tr><th>Project</th><th>Gates</th><th>Passed</th><th>Failed</th><th>Status</th></tr></thead>
                <tbody id="gateBody"></tbody>
            </table></div></div>
        </div>

        <!-- Code Quality Trends -->
        <div class="col-md-6">
            <div class="card"><div class="card-header"><h6 class="mb-0">Quality Trends</h6></div>
            <div class="card-body" id="qualityTrend"><div class="text-muted text-center py-5">Quality trend data will be populated from quality reports</div></div></div>
        </div>
    </div>

    <!-- Review Results -->
    <div class="card mt-3"><div class="card-header"><h6 class="mb-0">Recent Review Results</h6></div>
    <div class="card-body p-0"><table class="table table-hover mb-0">
        <thead><tr><th>Project</th><th>Agent</th><th>Type</th><th>Result</th><th>Issues</th><th>Date</th></tr></thead>
        <tbody id="reviewBody"></tbody>
    </table></div></div>

    <!-- Traceability Matrix -->
    <div class="card mt-3"><div class="card-header"><h6 class="mb-0">Traceability Summary</h6></div>
    <div class="card-body">
        <div class="row text-center">
            <div class="col-md-3"><h5 id="traceReqs">0</h5><small class="text-muted">Requirements</small></div>
            <div class="col-md-3"><h5 id="traceStories">0</h5><small class="text-muted">Stories</small></div>
            <div class="col-md-3"><h5 id="traceCode">0</h5><small class="text-muted">Code Files</small></div>
            <div class="col-md-3"><h5 id="traceTests">0</h5><small class="text-muted">Tests</small></div>
        </div>
        <div class="progress mt-3" style="height:12px">
            <div class="progress-bar bg-success" id="traceBar" style="width:0%"></div>
        </div>
        <div class="text-center mt-1 small text-muted">End-to-End Traceability: <strong id="tracePct">0%</strong></div>
    </div></div>
</div>

@section Scripts {
<script>
    async function load() {
        const projects = await fetch('/api/projects').then(r=>r.json());
        document.getElementById('projectFilter').innerHTML = '<option value="">All Projects</option>' + projects.map(p=>`<option value="${p.id}">${esc(p.name)}</option>`).join('');
        document.getElementById('gateBody').innerHTML = projects.map(p => `
            <tr><td>${esc(p.name)}</td><td>7</td><td class="text-success">0</td><td class="text-danger">0</td>
            <td><span class="badge bg-secondary">Pending</span></td></tr>
        `).join('') || '<tr><td colspan="5" class="text-center text-muted">No projects</td></tr>';
        document.getElementById('reviewBody').innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No review results yet</td></tr>';
    }
    function esc(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }
    load();
</script>
}
