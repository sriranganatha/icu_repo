@page
@model HmsAgents.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Agent Pipeline Dashboard";
}

<div class="container-fluid mt-3">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-cpu"></i> HMS Multi-Agent Pipeline Dashboard</h2>
            <p class="text-muted mb-0">Monitor agents building the Hospital Management System in real time.</p>
        </div>
        <div class="col-auto d-flex align-items-center gap-2">
            <span id="connectionBadge" class="badge bg-secondary">Disconnected</span>
            <button id="btnRunPipeline" class="btn btn-primary" onclick="runPipeline()">
                <i class="bi bi-play-fill"></i> Run Full Pipeline
            </button>
        </div>
    </div>

    <!-- Configuration Panel -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#configPanel" role="button">
            <span><i class="bi bi-gear"></i> Pipeline Configuration <small class="text-muted ms-2">(click to expand)</small></span>
            <span class="d-flex gap-2" onclick="event.stopPropagation()">
                <button class="btn btn-sm btn-outline-success" onclick="saveConfig()" title="Save config to file"><i class="bi bi-save"></i> Save</button>
                <button class="btn btn-sm btn-outline-info" onclick="loadConfig()" title="Load saved config"><i class="bi bi-folder2-open"></i> Load</button>
            </span>
        </div>
        <div class="collapse show" id="configPanel">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="bi bi-folder2-open me-1"></i>Requirements Path</label>
                        <input type="text" id="inputReqsPath" class="form-control" placeholder="e.g. C:\sri\mywork\icu\docs" />
                        <small class="text-muted">Folder containing requirement markdown files</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="bi bi-folder-plus me-1"></i>Output Path</label>
                        <input type="text" id="inputOutputPath" class="form-control" placeholder="e.g. C:\sri\mywork\icu\src" />
                        <small class="text-muted">Target folder for generated solution code</small>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="bi bi-box me-1"></i>Docker Container Name</label>
                        <input type="text" id="inputContainerName" class="form-control" value="hms-postgres" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="bi bi-server me-1"></i>DB Hostname</label>
                        <input type="text" id="inputDbHost" class="form-control" value="localhost" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold"><i class="bi bi-hdd-network me-1"></i>DB Port</label>
                        <input type="number" id="inputDbPort" class="form-control" value="5432" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold"><i class="bi bi-person-badge me-1"></i>DB Username</label>
                        <input type="text" id="inputDbUser" class="form-control" value="hms_admin" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold"><i class="bi bi-database me-1"></i>Database Name</label>
                        <input type="text" id="inputDbName" class="form-control" value="hms_db" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="bi bi-shield-lock me-1"></i>DB Password</label>
                        <input type="password" id="inputDbPassword" class="form-control" value="hms_secure_pwd_2026!" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Solution Namespace</label>
                        <input type="text" id="inputNamespace" class="form-control" value="Hms" />
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch me-4">
                            <input class="form-check-input" type="checkbox" id="chkSpinDocker" checked />
                            <label class="form-check-label" for="chkSpinDocker">Spin up Docker DB</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="chkExecDdl" checked />
                            <label class="form-check-label" for="chkExecDdl">Execute DDL</label>
                        </div>
                    </div>
                </div>
                <!-- Service Port Mapping -->
                <hr class="my-3" />
                <div class="d-flex align-items-center mb-2">
                    <i class="bi bi-diagram-3 me-2 text-primary"></i>
                    <span class="fw-semibold">Service Port Mapping</span>
                    <small class="text-muted ms-2">Change ports if another service is already using a port</small>
                </div>
                <div class="row g-2">
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Patient</span>
                            <input type="number" id="portPatient" class="form-control" value="5101" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Encounter</span>
                            <input type="number" id="portEncounter" class="form-control" value="5102" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Inpatient</span>
                            <input type="number" id="portInpatient" class="form-control" value="5103" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Emergency</span>
                            <input type="number" id="portEmergency" class="form-control" value="5104" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Diagnostics</span>
                            <input type="number" id="portDiagnostics" class="form-control" value="5105" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Revenue</span>
                            <input type="number" id="portRevenue" class="form-control" value="5106" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Audit</span>
                            <input type="number" id="portAudit" class="form-control" value="5107" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">AI</span>
                            <input type="number" id="portAi" class="form-control" value="5108" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">API Gateway</span>
                            <input type="number" id="portGateway" class="form-control" value="5100" />
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text" style="min-width:95px">Kafka</span>
                            <input type="number" id="portKafka" class="form-control" value="9092" />
                        </div>
                    </div>
                </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h6 class="card-title">Requirements</h6>
                    <h2 id="statReqs" class="mb-0">0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h6 class="card-title">Artifacts Generated</h6>
                    <h2 id="statArtifacts" class="mb-0">0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning">
                <div class="card-body">
                    <h6 class="card-title">Review Findings</h6>
                    <h2 id="statFindings" class="mb-0">0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info">
                <div class="card-body">
                    <h6 class="card-title">Pipeline Time</h6>
                    <h2 id="statTime" class="mb-0">--</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Agent Cards Grid -->
    <div class="row mb-4 g-3">
        <div class="col-md-4 col-lg-3" id="card-RequirementsReader">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Requirements Reader", Icon = "bi-file-earmark-text", AgentKey = "RequirementsReader", Description = "Scans icu/docs for structured requirements" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Database">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Database Agent", Icon = "bi-database", AgentKey = "Database", Description = "Generates EF Core entities, DbContext, repos" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-ServiceLayer">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Service Layer Agent", Icon = "bi-layers", AgentKey = "ServiceLayer", Description = "Generates DTOs, service interfaces & impls" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Application">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Application Agent", Icon = "bi-window-stack", AgentKey = "Application", Description = "Generates Razor Pages, ViewModels, layouts" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Integration">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Integration Agent", Icon = "bi-plug", AgentKey = "Integration", Description = "Generates HL7/FHIR adapters, event publisher" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Testing">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Testing Agent", Icon = "bi-check2-circle", AgentKey = "Testing", Description = "Generates unit & integration test stubs" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Review">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Review Agent", Icon = "bi-shield-check", AgentKey = "Review", Description = "Reviews code against requirements & security" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Supervisor">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Supervisor Agent", Icon = "bi-eye", AgentKey = "Supervisor", Description = "Monitors agents, diagnoses failures, remediates" })
        </div>
        <div class="col-md-4 col-lg-3" id="card-Orchestrator">
            @await Html.PartialAsync("_AgentCard", new HmsAgents.Web.Pages.AgentCardModel { Name = "Orchestrator", Icon = "bi-diagram-3", AgentKey = "Orchestrator", Description = "Coordinates pipeline stages sequentially" })
        </div>
    </div>

    <!-- NOC Charts Row 1 — Timeline + Event Throughput -->
    <div class="row mb-4 g-3">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><i class="bi bi-bar-chart-steps"></i> Agent Execution Timeline</div>
                <div class="card-body" style="height:260px;">
                    <canvas id="chartTimeline"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-activity"></i> Event Throughput <span class="badge bg-success ms-2" id="epsLabel">0 evt/s</span></div>
                <div class="card-body" style="height:260px;">
                    <canvas id="chartThroughput"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- NOC Charts Row 2 — Artifacts by Service + Layer + Severity -->
    <div class="row mb-4 g-3">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-diagram-3"></i> Artifacts by Microservice</div>
                <div class="card-body d-flex justify-content-center" style="height:280px;">
                    <canvas id="chartByService"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-stack"></i> Artifacts by Layer</div>
                <div class="card-body" style="height:280px;">
                    <canvas id="chartByLayer"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-shield-exclamation"></i> Review Severity Breakdown</div>
                <div class="card-body d-flex justify-content-center" style="height:280px;">
                    <canvas id="chartSeverity"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- NOC Row 3 — Agent Health Heatmap + Microservice Dependency -->
    <div class="row mb-4 g-3">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="bi bi-grid-3x3"></i> Agent Health Status</div>
                <div class="card-body p-3">
                    <div id="agentHeatmap" class="d-flex flex-wrap gap-2 justify-content-center" style="min-height:80px;"></div>
                    <div class="mt-2 d-flex gap-3 justify-content-center" style="font-size:0.75rem;">
                        <span><span class="badge bg-secondary">&nbsp;</span> Idle</span>
                        <span><span class="badge bg-primary">&nbsp;</span> Running</span>
                        <span><span class="badge bg-success">&nbsp;</span> Completed</span>
                        <span><span class="badge bg-danger">&nbsp;</span> Failed</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="bi bi-bezier2"></i> Microservice Event Flow</div>
                <div class="card-body p-3" style="min-height:120px;">
                    <div id="serviceFlow" class="d-flex flex-wrap gap-2 justify-content-center align-items-center"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Unit Test Diagnostics Row -->
    <div class="row mb-4 g-3">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-clipboard2-check"></i> Test Outcome Summary
                    <span class="badge bg-info ms-2" id="testTotalBadge">0 tests</span>
                </div>
                <div class="card-body d-flex justify-content-center" style="height:260px;">
                    <canvas id="chartTestOutcome"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-bar-chart"></i> Tests by Agent</div>
                <div class="card-body" style="height:260px;">
                    <canvas id="chartTestsByAgent"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-tags"></i> Tests by Category</div>
                <div class="card-body" style="height:260px;">
                    <canvas id="chartTestsByCategory"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Test Diagnostics Detail Table -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-journal-medical"></i> Test Diagnostics &amp; Remediation</span>
                    <div class="d-flex gap-2">
                        <select id="testFilterOutcome" class="form-select form-select-sm" style="width:auto;" onchange="filterTestTable()">
                            <option value="all">All Outcomes</option>
                            <option value="0">Passed</option>
                            <option value="1">Failed</option>
                            <option value="2">Skipped</option>
                            <option value="3">Remediated</option>
                        </select>
                        <select id="testFilterAgent" class="form-select form-select-sm" style="width:auto;" onchange="filterTestTable()">
                            <option value="all">All Agents</option>
                        </select>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div style="max-height:400px;overflow-y:auto;">
                        <table class="table table-sm table-striped table-hover mb-0" id="testDiagTable">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th style="width:30px;"></th>
                                    <th>Test Name</th>
                                    <th>Agent</th>
                                    <th>Category</th>
                                    <th>Outcome</th>
                                    <th>Diagnostic</th>
                                    <th>Remediation</th>
                                    <th style="width:50px;">Attempt</th>
                                </tr>
                            </thead>
                            <tbody id="testDiagBody">
                                <tr><td colspan="8" class="text-center text-muted py-4">Run pipeline to see test diagnostics...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Live Event Log + Findings -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span><i class="bi bi-terminal"></i> Live Event Log</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="clearLog()">Clear</button>
                </div>
                <div class="card-body p-0">
                    <div id="eventLog" style="height:400px;overflow-y:auto;font-family:monospace;font-size:0.85rem;padding:0.75rem;background:#1e1e1e;color:#d4d4d4;">
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-exclamation-triangle"></i> Review Findings</div>
                <div class="card-body p-0">
                    <div id="findingsPanel" style="height:400px;overflow-y:auto;padding:0.75rem;">
                        <p class="text-muted text-center mt-5">Run pipeline to see review findings.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        // ─── NOC Chart State ─────────────────────────────────────────────
        const AGENTS = ["RequirementsReader","Database","ServiceLayer","Application","Integration","Testing","Review","Supervisor","Orchestrator"];
        const AGENT_LABELS = ["Reqs Reader","Database","Service","Application","Integration","Testing","Review","Supervisor","Orchestrator"];
        const SERVICES = ["Patient","Encounter","Inpatient","Emergency","Diagnostics","Revenue","Audit","AI"];
        const LAYERS = ["Database","Repository","Service","Dto","ViewModel","RazorPage","Integration","Test","Migration","Configuration"];
        const SVC_COLORS = ["#42a5f5","#66bb6a","#ffa726","#ef5350","#ab47bc","#26c6da","#8d6e63","#78909c"];
        const LAYER_COLORS = ["#1565c0","#2e7d32","#ef6c00","#c62828","#6a1b9a","#00838f","#4e342e","#37474f","#ad1457","#546e7a"];

        const nocState = {
            agentTiming: {},       // agentKey → { start, end, elapsed }
            artifactsByService: {},
            artifactsByLayer: {},
            severityCounts: [0,0,0,0,0,0], // Info, Warning, Error, Critical, Security, Compliance
            throughputLog: [],     // { time, count }
            eventCount: 0,
            lastEpsTick: Date.now(),
            agentStatuses: {}      // agentKey → status enum
        };

        // ─── Chart: Agent Timeline (horizontal bar) ─────────────────────
        const ctxTimeline = document.getElementById('chartTimeline').getContext('2d');
        const chartTimeline = new Chart(ctxTimeline, {
            type: 'bar',
            data: {
                labels: AGENT_LABELS,
                datasets: [{
                    label: 'Duration (ms)',
                    data: new Array(9).fill(0),
                    backgroundColor: AGENTS.map((_, i) => ['#42a5f5','#66bb6a','#ffa726','#ef5350','#ab47bc','#26c6da','#8d6e63','#e91e63','#78909c'][i]),
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false },
                    title: { display: false } },
                scales: {
                    x: { title: { display: true, text: 'ms', color: '#888' }, grid: { color: 'rgba(0,0,0,0.05)' } },
                    y: { grid: { display: false } }
                }
            }
        });

        // ─── Chart: Event Throughput (real-time line) ────────────────────
        const ctxThroughput = document.getElementById('chartThroughput').getContext('2d');
        const chartThroughput = new Chart(ctxThroughput, {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Events/sec',
                    data: [],
                    borderColor: '#4caf50',
                    backgroundColor: 'rgba(76,175,80,0.1)',
                    fill: true, tension: 0.4, pointRadius: 0,
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                animation: { duration: 300 },
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: true, grid: { display: false }, ticks: { maxTicksLimit: 8, font: { size: 10 } } },
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, title: { display: true, text: 'evt/s', color: '#888' } }
                }
            }
        });

        // ─── Chart: Artifacts by Microservice (doughnut) ─────────────────
        const ctxByService = document.getElementById('chartByService').getContext('2d');
        const chartByService = new Chart(ctxByService, {
            type: 'doughnut',
            data: {
                labels: SERVICES,
                datasets: [{ data: new Array(8).fill(0), backgroundColor: SVC_COLORS, borderWidth: 0 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '55%',
                plugins: {
                    legend: { position: 'right', labels: { boxWidth: 12, font: { size: 11 } } }
                }
            }
        });

        // ─── Chart: Artifacts by Layer (bar) ─────────────────────────────
        const ctxByLayer = document.getElementById('chartByLayer').getContext('2d');
        const chartByLayer = new Chart(ctxByLayer, {
            type: 'bar',
            data: {
                labels: LAYERS,
                datasets: [{
                    label: 'Count',
                    data: new Array(10).fill(0),
                    backgroundColor: LAYER_COLORS,
                    borderRadius: 3
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 10 }, maxRotation: 45 } },
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { stepSize: 1 } }
                }
            }
        });

        // ─── Chart: Review Severity (polar area) ────────────────────────
        const ctxSeverity = document.getElementById('chartSeverity').getContext('2d');
        const chartSeverity = new Chart(ctxSeverity, {
            type: 'polarArea',
            data: {
                labels: ['Info','Warning','Error','Critical','Security','Compliance'],
                datasets: [{
                    data: [0,0,0,0,0,0],
                    backgroundColor: ['rgba(33,150,243,0.6)','rgba(255,193,7,0.6)','rgba(244,67,54,0.6)','rgba(183,28,28,0.7)','rgba(156,39,176,0.6)','rgba(255,152,0,0.6)'],
                    borderWidth: 1
                }]
            },
