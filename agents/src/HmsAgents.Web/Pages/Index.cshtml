        initHeatmap();
        initServiceFlow();

        // ─── NOC Update Functions ───────────────────────────────────────
        function nocUpdateAgentTiming(agentKey, status, elapsedMs) {
            const idx = AGENTS.indexOf(getAgentName(agentKey));
            if (idx < 0) return;
            const name = getAgentName(agentKey);

            nocState.agentStatuses[name] = status;

            if (status === 1) { // Running
                nocState.agentTiming[name] = { start: Date.now(), end: null, elapsed: 0 };
            }
            if (status === 3 || status === 4) { // Completed or Failed
                if (nocState.agentTiming[name]) {
                    nocState.agentTiming[name].end = Date.now();
                    nocState.agentTiming[name].elapsed = elapsedMs;
                }
                chartTimeline.data.datasets[0].data[idx] = elapsedMs;
                chartTimeline.update('none');
            }

            // Heatmap
            const hmEl = document.getElementById(`hm-${name}`);
            if (hmEl) {
                const colors = { 0: '#dee2e6', 1: '#42a5f5', 2: '#90caf9', 3: '#66bb6a', 4: '#ef5350' };
                const textColors = { 0: '#333', 1: '#fff', 2: '#333', 3: '#fff', 4: '#fff' };
                hmEl.style.background = colors[status] || '#dee2e6';
                hmEl.style.color = textColors[status] || '#333';
                const timeEl = document.getElementById(`hm-time-${name}`);
                if (timeEl && elapsedMs > 0) timeEl.textContent = elapsedMs.toFixed(0) + 'ms';
            }
        }

        function nocTrackArtifact(agentKey, artifactCount) {
            // Map agent → likely service contributions (heuristic from path)
            const agentName = getAgentName(agentKey);
            if (!nocState.artifactsByService[agentName])
                nocState.artifactsByService[agentName] = artifactCount;
            else
                nocState.artifactsByService[agentName] = artifactCount;
        }

        function nocTrackEvent() {
            nocState.eventCount++;
        }

        function nocUpdateServiceArtifacts(data) {
            // data.artifacts array from PipelineComplete
            if (!data.artifacts) return;
            const svcCounts = {};
            const layerCounts = {};
            SERVICES.forEach(s => svcCounts[s] = 0);
            LAYERS.forEach(l => layerCounts[l] = 0);

            data.artifacts.forEach(a => {
                // Map by path prefix to service
                const path = a.relativePath || '';
                SERVICES.forEach((svc, i) => {
                    if (path.toLowerCase().includes(svc.toLowerCase())) svcCounts[svc]++;
                });

                // Map by layer enum
                const layerName = LAYERS[a.layer] || '';
                if (layerName) layerCounts[layerName] = (layerCounts[layerName] || 0) + 1;
            });

            chartByService.data.datasets[0].data = SERVICES.map(s => svcCounts[s]);
            chartByService.update();

            chartByLayer.data.datasets[0].data = LAYERS.map(l => layerCounts[l] || 0);
            chartByLayer.update();

            // Light up service flow nodes
            SERVICES.forEach(svc => {
                const el = document.getElementById(`sf-${svc}`);
                if (el && svcCounts[svc] > 0) {
                    el.style.background = '#e8f5e9';
                    el.style.borderColor = '#4caf50';
                }
            });
        }

        function nocUpdateSeverity(findings) {
            if (!findings || !findings.length) return;
            const counts = [0,0,0,0,0,0];
            findings.forEach(f => { if (f.severity >= 0 && f.severity <= 5) counts[f.severity]++; });
            chartSeverity.data.datasets[0].data = counts;
            chartSeverity.update();
        }

        // Throughput ticker — every 2s
        setInterval(() => {
            const now = Date.now();
            const dt = (now - nocState.lastEpsTick) / 1000;
            const eps = dt > 0 ? (nocState.eventCount / dt) : 0;
            nocState.eventCount = 0;
            nocState.lastEpsTick = now;

            const label = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            const ds = chartThroughput.data;
            ds.labels.push(label);
            ds.datasets[0].data.push(Math.round(eps * 10) / 10);
            if (ds.labels.length > 30) { ds.labels.shift(); ds.datasets[0].data.shift(); }
            chartThroughput.update('none');

            document.getElementById('epsLabel').textContent = eps.toFixed(1) + ' evt/s';
        }, 2000);

        // ─── Chart: Test Outcome (doughnut) ────────────────────────────
        const ctxTestOutcome = document.getElementById('chartTestOutcome').getContext('2d');
        const chartTestOutcome = new Chart(ctxTestOutcome, {
            type: 'doughnut',
            data: {
                labels: ['Passed', 'Failed', 'Skipped', 'Remediated'],
                datasets: [{
                    data: [0, 0, 0, 0],
                    backgroundColor: ['#4caf50', '#f44336', '#9e9e9e', '#ff9800'],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '50%',
                plugins: {
                    legend: { position: 'right', labels: { boxWidth: 12, font: { size: 11 } } }
                }
            }
        });

        // ─── Chart: Tests by Agent (stacked bar) ────────────────────────
        const ctxTestsByAgent = document.getElementById('chartTestsByAgent').getContext('2d');
        const chartTestsByAgent = new Chart(ctxTestsByAgent, {
            type: 'bar',
            data: {
                labels: [],
                datasets: [
                    { label: 'Passed', data: [], backgroundColor: '#4caf50', borderRadius: 2 },
                    { label: 'Failed', data: [], backgroundColor: '#f44336', borderRadius: 2 },
                    { label: 'Remediated', data: [], backgroundColor: '#ff9800', borderRadius: 2 },
                    { label: 'Skipped', data: [], backgroundColor: '#9e9e9e', borderRadius: 2 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', labels: { boxWidth: 10, font: { size: 10 } } } },
                scales: {
                    x: { stacked: true, grid: { display: false }, ticks: { font: { size: 10 } } },
                    y: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });

        // ─── Chart: Tests by Category (horizontal bar) ──────────────────
        const ctxTestsByCategory = document.getElementById('chartTestsByCategory').getContext('2d');
        const chartTestsByCategory = new Chart(ctxTestsByCategory, {
            type: 'bar',
            data: {
                labels: [],
                datasets: [
                    { label: 'Passed', data: [], backgroundColor: '#4caf50' },
                    { label: 'Failed', data: [], backgroundColor: '#f44336' },
                    { label: 'Remediated', data: [], backgroundColor: '#ff9800' }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', labels: { boxWidth: 10, font: { size: 10 } } } },
                scales: {
                    x: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } },
                    y: { stacked: true, grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });

        // ─── Test Diagnostics State & Functions ─────────────────────────
        let allTestDiagnostics = [];

        function nocUpdateTestDiagnostics(diagnostics) {
            if (!diagnostics || !diagnostics.length) return;
            allTestDiagnostics = diagnostics;

            // Outcome summary
            const outcomes = [0, 0, 0, 0]; // Passed, Failed, Skipped, Remediated
            diagnostics.forEach(d => { if (d.outcome >= 0 && d.outcome <= 3) outcomes[d.outcome]++; });
            chartTestOutcome.data.datasets[0].data = outcomes;
            chartTestOutcome.update();
            document.getElementById('testTotalBadge').textContent = `${diagnostics.length} tests`;

            // Tests by agent
            const agentMap = {};
            diagnostics.forEach(d => {
                if (!agentMap[d.agentUnderTest]) agentMap[d.agentUnderTest] = [0,0,0,0];
                if (d.outcome >= 0 && d.outcome <= 3) agentMap[d.agentUnderTest][d.outcome]++;
            });
            const agentNames = Object.keys(agentMap);
            chartTestsByAgent.data.labels = agentNames;
            chartTestsByAgent.data.datasets[0].data = agentNames.map(a => agentMap[a][0]);
            chartTestsByAgent.data.datasets[1].data = agentNames.map(a => agentMap[a][1]);
            chartTestsByAgent.data.datasets[2].data = agentNames.map(a => agentMap[a][3]);
            chartTestsByAgent.data.datasets[3].data = agentNames.map(a => agentMap[a][2]);
            chartTestsByAgent.update();

            // Tests by category
            const catMap = {};
            diagnostics.forEach(d => {
                if (!catMap[d.category]) catMap[d.category] = [0,0,0];
                if (d.outcome === 0) catMap[d.category][0]++;
                else if (d.outcome === 1) catMap[d.category][1]++;
                else if (d.outcome === 3) catMap[d.category][2]++;
            });
            const cats = Object.keys(catMap);
            chartTestsByCategory.data.labels = cats;
            chartTestsByCategory.data.datasets[0].data = cats.map(c => catMap[c][0]);
            chartTestsByCategory.data.datasets[1].data = cats.map(c => catMap[c][1]);
            chartTestsByCategory.data.datasets[2].data = cats.map(c => catMap[c][2]);
            chartTestsByCategory.update();

            // Populate filter dropdown
            const agentFilter = document.getElementById('testFilterAgent');
            agentFilter.innerHTML = '<option value="all">All Agents</option>' +
                agentNames.map(a => `<option value="${a}">${a}</option>`).join('');

            // Render table
            renderTestTable(diagnostics);
        }

        function renderTestTable(diagnostics) {
            const tbody = document.getElementById('testDiagBody');
            const outcomeIcons = ['<i class="bi bi-check-circle-fill text-success"></i>',
                                  '<i class="bi bi-x-circle-fill text-danger"></i>',
                                  '<i class="bi bi-dash-circle text-secondary"></i>',
                                  '<i class="bi bi-arrow-repeat text-warning"></i>'];
            const outcomeLabels = ['Passed','Failed','Skipped','Remediated'];
            const outcomeBadges = ['bg-success','bg-danger','bg-secondary','bg-warning text-dark'];

            tbody.innerHTML = diagnostics.map(d => {
                const oc = d.outcome >= 0 && d.outcome <= 3 ? d.outcome : 2;
                return `<tr class="${oc === 1 ? 'table-danger' : oc === 3 ? 'table-warning' : ''}">
                    <td>${outcomeIcons[oc]}</td>
                    <td style="font-size:0.8rem;font-family:monospace;">${escapeHtml(d.testName)}</td>
                    <td><span class="badge bg-primary" style="font-size:0.7rem;">${escapeHtml(d.agentUnderTest)}</span></td>
                    <td><span class="badge bg-info text-dark" style="font-size:0.65rem;">${escapeHtml(d.category)}</span></td>
                    <td><span class="badge ${outcomeBadges[oc]}" style="font-size:0.7rem;">${outcomeLabels[oc]}</span></td>
                    <td style="font-size:0.78rem;">${escapeHtml(d.diagnostic)}</td>
                    <td style="font-size:0.78rem;${oc === 1 ? 'color:#d32f2f;font-weight:600;' : oc === 3 ? 'color:#e65100;font-weight:600;' : ''}">${escapeHtml(d.remediation)}</td>
                    <td class="text-center">${d.attemptNumber > 1 ? `<span class="badge bg-warning text-dark">${d.attemptNumber}</span>` : '1'}</td>
                </tr>`;
            }).join('');
        }

        function filterTestTable() {
            const outcomeFilter = document.getElementById('testFilterOutcome').value;
            const agentFilter = document.getElementById('testFilterAgent').value;
            let filtered = allTestDiagnostics;
            if (outcomeFilter !== 'all') filtered = filtered.filter(d => d.outcome === parseInt(outcomeFilter));
            if (agentFilter !== 'all') filtered = filtered.filter(d => d.agentUnderTest === agentFilter);
            renderTestTable(filtered);
        }

        function escapeHtml(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

        // ─── SignalR ────────────────────────────────────────────────────
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/pipeline")
            .withAutomaticReconnect()
            .build();

        connection.on("Connected", msg => {
            document.getElementById("connectionBadge").className = "badge bg-success";
            document.getElementById("connectionBadge").textContent = "Connected";
            appendLog("system", msg);
        });

        connection.on("PipelineEvent", evt => {
            updateAgentCard(evt.agent, evt.status, evt.message, evt.artifactCount, evt.findingCount, evt.elapsedMs);
            appendLog(getStatusClass(evt.status), `[${getAgentName(evt.agent)}] ${evt.message} (${evt.elapsedMs.toFixed(0)}ms)${evt.retryAttempt > 0 ? ' [retry #' + evt.retryAttempt + ']' : ''}`);

            // NOC updates
            nocTrackEvent();
            nocUpdateAgentTiming(evt.agent, evt.status, evt.elapsedMs);
            nocTrackArtifact(evt.agent, evt.artifactCount);

            // Inline test diagnostics from Supervisor events
            if (evt.testDiagnostics && evt.testDiagnostics.length > 0) {
                nocUpdateTestDiagnostics(evt.testDiagnostics);
                appendLog('system', `[Supervisor] ${evt.testDiagnostics.length} test diagnostics received`);
            }
        });

        connection.on("PipelineComplete", data => {
            document.getElementById("statReqs").textContent = data.requirementCount;
            document.getElementById("statArtifacts").textContent = data.artifactCount;
            document.getElementById("statFindings").textContent = data.findingCount;
            document.getElementById("statTime").textContent = data.durationMs.toFixed(0) + "ms";
            appendLog("success", `Pipeline complete: ${data.artifactCount} artifacts, ${data.findingCount} findings, ${data.testDiagnosticCount || 0} tests`);
            document.getElementById("btnRunPipeline").disabled = false;
            if (data.findings && data.findings.length > 0) {
                renderFindings(data.findings);
                nocUpdateSeverity(data.findings);
            }
            if (data.artifacts) nocUpdateServiceArtifacts(data);
            if (data.testDiagnostics && data.testDiagnostics.length > 0) {
                nocUpdateTestDiagnostics(data.testDiagnostics);
            }

            // Final: update layer chart from cumulative agent artifact counts
            updateLayerChartFromAgents();
        });

        connection.onreconnecting(() => {
            document.getElementById("connectionBadge").className = "badge bg-warning";
            document.getElementById("connectionBadge").textContent = "Reconnecting...";
        });
        connection.onreconnected(() => {
            document.getElementById("connectionBadge").className = "badge bg-success";
            document.getElementById("connectionBadge").textContent = "Connected";
        });
        connection.start().catch(err => appendLog("error", "Connection failed: " + err));

        // ─── Config Save / Load ─────────────────────────────────────────
        const CONFIG_FIELDS = [
            'inputReqsPath', 'inputOutputPath', 'inputNamespace',
            'inputContainerName', 'inputDbHost', 'inputDbPort', 'inputDbUser',
            'inputDbName', 'inputDbPassword',
            'portPatient', 'portEncounter', 'portInpatient', 'portEmergency',
            'portDiagnostics', 'portRevenue', 'portAudit', 'portAi',
            'portGateway', 'portKafka'
        ];
        const CONFIG_CHECKS = ['chkSpinDocker', 'chkExecDdl'];

        async function saveConfig() {
            const cfg = {};
            CONFIG_FIELDS.forEach(id => { cfg[id] = document.getElementById(id)?.value ?? ''; });
            CONFIG_CHECKS.forEach(id => { cfg[id] = document.getElementById(id)?.checked ?? false; });
            try {
                const res = await fetch('/api/pipeline/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(cfg)
                });
                if (res.ok) appendLog('system', 'Configuration saved.');
                else appendLog('error', 'Failed to save config: ' + res.statusText);
            } catch (e) { appendLog('error', 'Save config error: ' + e.message); }
        }

        async function loadConfig() {
            try {
                const res = await fetch('/api/pipeline/config');
                if (!res.ok) { appendLog('error', 'No saved config found.'); return; }
                const cfg = await res.json();
                if (!cfg || Object.keys(cfg).length === 0) { appendLog('system', 'No saved configuration found.'); return; }
                CONFIG_FIELDS.forEach(id => {
                    const el = document.getElementById(id);
                    if (el && cfg[id] !== undefined) el.value = cfg[id];
                });
                CONFIG_CHECKS.forEach(id => {
                    const el = document.getElementById(id);
                    if (el && cfg[id] !== undefined) el.checked = cfg[id];
                });
                appendLog('system', 'Configuration loaded from saved file.');
            } catch (e) { appendLog('error', 'Load config error: ' + e.message); }
        }

        // Auto-load config on page start
        loadConfig();

        // ─── Pipeline + Card logic ──────────────────────────────────────
        async function runPipeline() {
            document.getElementById("btnRunPipeline").disabled = true;
            resetCards();
            nocResetCharts();
            clearLog();

            const reqsPath = document.getElementById('inputReqsPath').value.trim();
            const outputPath = document.getElementById('inputOutputPath').value.trim();
            if (!reqsPath || !outputPath) {
                appendLog('error', 'Requirements Path and Output Path are required.');
                document.getElementById('btnRunPipeline').disabled = false;
                return;
            }

            const body = {
                requirementsPath: reqsPath,
                outputPath: outputPath,
                solutionNamespace: document.getElementById('inputNamespace').value || 'Hms',
                dockerContainerName: document.getElementById('inputContainerName').value || 'hms-postgres',
                dbHost: document.getElementById('inputDbHost').value || 'localhost',
                dbPort: parseInt(document.getElementById('inputDbPort').value) || 5432,
                dbUser: document.getElementById('inputDbUser').value || 'hms_admin',
                dbName: document.getElementById('inputDbName').value || 'hms_db',
                dbPassword: document.getElementById('inputDbPassword').value || 'hms_secure_pwd_2026!',
                spinUpDocker: document.getElementById('chkSpinDocker').checked,
                executeDdl: document.getElementById('chkExecDdl').checked,
                servicePorts: {
                    patient: parseInt(document.getElementById('portPatient').value) || 5101,
                    encounter: parseInt(document.getElementById('portEncounter').value) || 5102,
                    inpatient: parseInt(document.getElementById('portInpatient').value) || 5103,
                    emergency: parseInt(document.getElementById('portEmergency').value) || 5104,
                    diagnostics: parseInt(document.getElementById('portDiagnostics').value) || 5105,
                    revenue: parseInt(document.getElementById('portRevenue').value) || 5106,
                    audit: parseInt(document.getElementById('portAudit').value) || 5107,
                    ai: parseInt(document.getElementById('portAi').value) || 5108,
                    gateway: parseInt(document.getElementById('portGateway').value) || 5100,
                    kafka: parseInt(document.getElementById('portKafka').value) || 9092
                }
            };

            appendLog('system', `Starting pipeline — reqs: ${body.requirementsPath}, output: ${body.outputPath}`);
            if (body.spinUpDocker) appendLog('system', `Docker: ${body.dockerContainerName} \u2014 ${body.dbUser}@@${body.dbHost}:${body.dbPort}/${body.dbName}`);

            try {
                const res = await fetch('/api/pipeline/run', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) appendLog('error', 'Pipeline trigger failed: ' + res.statusText);
            } catch (e) {
                appendLog('error', 'Request failed: ' + e.message);
                document.getElementById('btnRunPipeline').disabled = false;
            }
        }

        function updateAgentCard(agentKey, status, message, artifacts, findings, elapsed) {
            const agentName = getAgentName(agentKey);
            const card = document.querySelector(`#card-${agentName}`);
            if (!card) return;
            const statusBadge = card.querySelector(".agent-status");
            const artifactSpan = card.querySelector(".agent-artifacts");
            const messageSpan = card.querySelector(".agent-message");
            const progressBar = card.querySelector(".progress-bar");
            if (statusBadge) { statusBadge.className = `badge agent-status ${getStatusBadgeClass(status)}`; statusBadge.textContent = getStatusText(status); }
            if (artifactSpan) artifactSpan.textContent = artifacts;
            if (messageSpan) messageSpan.textContent = message;
            if (progressBar) { progressBar.style.width = status >= 3 ? "100%" : status >= 1 ? "50%" : "0%"; progressBar.className = `progress-bar ${getProgressClass(status)}`; }
        }

        function resetCards() {
            document.querySelectorAll(".agent-status").forEach(el => { el.className = "badge agent-status bg-secondary"; el.textContent = "Idle"; });
            document.querySelectorAll(".agent-artifacts").forEach(el => el.textContent = "0");
            document.querySelectorAll(".agent-message").forEach(el => el.textContent = "Waiting...");
            document.querySelectorAll(".progress-bar").forEach(el => el.style.width = "0%");
            ["statReqs","statArtifacts","statFindings"].forEach(id => document.getElementById(id).textContent = "0");
            document.getElementById("statTime").textContent = "--";
            document.getElementById("findingsPanel").innerHTML = '<p class="text-muted text-center mt-5">Running...</p>';
        }

        function nocResetCharts() {
            chartTimeline.data.datasets[0].data = new Array(9).fill(0);
            chartTimeline.update('none');
            chartByService.data.datasets[0].data = new Array(8).fill(0);
            chartByService.update('none');
            chartByLayer.data.datasets[0].data = new Array(10).fill(0);
            chartByLayer.update('none');
            chartSeverity.data.datasets[0].data = [0,0,0,0,0,0];
            chartSeverity.update('none');

            // Reset test charts
            chartTestOutcome.data.datasets[0].data = [0,0,0,0];
            chartTestOutcome.update('none');
            chartTestsByAgent.data.labels = [];
            chartTestsByAgent.data.datasets.forEach(ds => ds.data = []);
            chartTestsByAgent.update('none');
            chartTestsByCategory.data.labels = [];
            chartTestsByCategory.data.datasets.forEach(ds => ds.data = []);
            chartTestsByCategory.update('none');
            allTestDiagnostics = [];
            document.getElementById('testDiagBody').innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Running...</td></tr>';
            document.getElementById('testTotalBadge').textContent = '0 tests';

            nocState.agentTiming = {};
            nocState.artifactsByService = {};
            nocState.artifactsByLayer = {};
            nocState.severityCounts = [0,0,0,0,0,0];
            nocState.agentStatuses = {};
            initHeatmap();
            // Reset service flow nodes
            SERVICES.forEach(svc => {
                const el = document.getElementById(`sf-${svc}`);
                if (el) { el.style.background = '#f5f5f5'; el.style.borderColor = '#dee2e6'; }
            });
        }

        function updateLayerChartFromAgents() {
            // Use agent-to-layer mapping heuristic
            const agentLayerMap = {
                'Database': [0,1,8],       // Database, Repository, Migration
                'ServiceLayer': [2,3,6],   // Service, Dto, Integration
                'Application': [5,9],      // RazorPage, Configuration
                'Integration': [6],        // Integration
                'Testing': [7],            // Test
                'Review': []
            };
            const layerData = new Array(10).fill(0);
            Object.entries(nocState.artifactsByService).forEach(([agent, count]) => {
                const layers = agentLayerMap[agent] || [];
                if (layers.length > 0) {
                    const per = Math.ceil(count / layers.length);
                    layers.forEach(li => layerData[li] += per);
                }
            });
            chartByLayer.data.datasets[0].data = layerData;
            chartByLayer.update();
        }

        // ─── Utilities ──────────────────────────────────────────────────
        function appendLog(cls, msg) {
            const log = document.getElementById("eventLog");
            const ts = new Date().toLocaleTimeString();
            const colors = { system: "#569cd6", success: "#4ec9b0", error: "#f44747", warning: "#dcdcaa" };
            log.innerHTML += `<div style="color:${colors[cls] || '#d4d4d4'}">[${ts}] ${msg}</div>`;
            log.scrollTop = log.scrollHeight;
        }
        function clearLog() { document.getElementById("eventLog").innerHTML = ""; }

        function renderFindings(findings) {
            const panel = document.getElementById("findingsPanel");
            panel.innerHTML = findings.map(f => {
                const sev = f.severity >= 4 ? "danger" : f.severity >= 3 ? "warning" : "info";
                return `<div class="alert alert-${sev} py-1 px-2 mb-1" style="font-size:0.8rem"><strong>${f.category}</strong>: ${f.message}${f.filePath ? `<br/><small class="text-muted">${f.filePath}</small>` : ""}</div>`;
            }).join("");
        }

        function getAgentName(k) { const n=["Orchestrator","RequirementsReader","Database","ServiceLayer","Application","Integration","Review","Testing","Supervisor"]; return typeof k==="number"?n[k]||k:k; }
        function getStatusText(s) { return ["Idle","Running","Waiting","Completed","Failed","Review Pending"][s]||s; }
        function getStatusClass(s) { return ["system","warning","system","success","error","warning"][s]||"system"; }
        function getStatusBadgeClass(s) { return ["bg-secondary","bg-primary","bg-info","bg-success","bg-danger","bg-warning"][s]||"bg-secondary"; }
        function getProgressClass(s) { return ["","bg-primary progress-bar-striped progress-bar-animated","bg-info","bg-success","bg-danger","bg-warning"][s]||""; }
    </script>
}
