@page
@model GNex.Studio.Pages.Projects.StarterKitsModel
@{ ViewData["Title"] = "Starter Kits"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-rocket-takeoff me-2"></i>Starter Kits</h2>
            <p class="text-muted mb-0">Choose a pre-configured starter kit to bootstrap your project</p>
        </div>
        <div class="d-flex gap-2">
            <div class="input-group" style="width:300px;">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control" placeholder="Search kits..." id="searchKits" />
            </div>
            <select class="form-select" id="categoryFilter" style="width:180px;">
                <option value="">All Categories</option>
                <option value="web">Web App</option>
                <option value="api">API Service</option>
                <option value="data">Data Pipeline</option>
                <option value="mobile">Mobile</option>
                <option value="enterprise">Enterprise</option>
            </select>
        </div>
    </div>

    <!-- Starter Kit Cards -->
    <div class="row g-4" id="kitsGrid">
        <!-- SaaS API -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-primary kit-card" data-category="api">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                            <i class="bi bi-cloud-arrow-up text-primary" style="font-size:1.5rem;"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">SaaS API</h5>
                            <small class="text-muted">Modern API service</small>
                        </div>
                        <span class="badge bg-primary ms-auto">Popular</span>
                    </div>
                    <p class="card-text text-muted">FastAPI + PostgreSQL + Redis + Docker + GitHub Actions. Production-ready API with authentication, rate limiting, and observability.</p>
                    <div class="mb-3">
                        <span class="badge bg-light text-dark me-1">Python</span>
                        <span class="badge bg-light text-dark me-1">FastAPI</span>
                        <span class="badge bg-light text-dark me-1">PostgreSQL</span>
                        <span class="badge bg-light text-dark me-1">Redis</span>
                        <span class="badge bg-light text-dark me-1">Docker</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-diagram-3 me-1"></i>Microservices</small>
                        <button class="btn btn-primary btn-sm" onclick="useKit('saas-api')">
                            <i class="bi bi-arrow-right me-1"></i>Use This
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Full Stack Web -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 kit-card" data-category="web">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                            <i class="bi bi-window-stack text-success" style="font-size:1.5rem;"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Full Stack Web</h5>
                            <small class="text-muted">Complete web application</small>
                        </div>
                    </div>
                    <p class="card-text text-muted">Next.js + Node.js + PostgreSQL + Vercel. Server-side rendering, API routes, and automated deployments.</p>
                    <div class="mb-3">
                        <span class="badge bg-light text-dark me-1">TypeScript</span>
                        <span class="badge bg-light text-dark me-1">Next.js</span>
                        <span class="badge bg-light text-dark me-1">Node.js</span>
                        <span class="badge bg-light text-dark me-1">PostgreSQL</span>
                        <span class="badge bg-light text-dark me-1">Vercel</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-diagram-3 me-1"></i>Monolith</small>
                        <button class="btn btn-primary btn-sm" onclick="useKit('fullstack-web')">
                            <i class="bi bi-arrow-right me-1"></i>Use This
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Pipeline -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 kit-card" data-category="data">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                            <i class="bi bi-diagram-2 text-warning" style="font-size:1.5rem;"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Data Pipeline</h5>
                            <small class="text-muted">ETL &amp; analytics</small>
                        </div>
                    </div>
                    <p class="card-text text-muted">Python + Airflow + Snowflake + dbt. Scheduled data ingestion, transformation, and warehouse loading.</p>
                    <div class="mb-3">
                        <span class="badge bg-light text-dark me-1">Python</span>
                        <span class="badge bg-light text-dark me-1">Airflow</span>
                        <span class="badge bg-light text-dark me-1">Snowflake</span>
                        <span class="badge bg-light text-dark me-1">dbt</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-diagram-3 me-1"></i>Pipeline</small>
                        <button class="btn btn-primary btn-sm" onclick="useKit('data-pipeline')">
                            <i class="bi bi-arrow-right me-1"></i>Use This
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- .NET Enterprise -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 kit-card" data-category="enterprise">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                            <i class="bi bi-building text-info" style="font-size:1.5rem;"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">.NET Enterprise</h5>
                            <small class="text-muted">Enterprise-grade platform</small>
                        </div>
                    </div>
                    <p class="card-text text-muted">ASP.NET Core + SQL Server + Azure + Terraform. Clean architecture, CQRS, multi-tenant ready.</p>
                    <div class="mb-3">
                        <span class="badge bg-light text-dark me-1">C#</span>
                        <span class="badge bg-light text-dark me-1">ASP.NET</span>
                        <span class="badge bg-light text-dark me-1">SQL Server</span>
                        <span class="badge bg-light text-dark me-1">Azure</span>
                        <span class="badge bg-light text-dark me-1">Terraform</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-layers me-1"></i>Clean Architecture</small>
                        <button class="btn btn-primary btn-sm" onclick="useKit('dotnet-enterprise')">
                            <i class="bi bi-arrow-right me-1"></i>Use This
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mobile -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 kit-card" data-category="mobile">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-danger bg-opacity-10 p-3 me-3">
                            <i class="bi bi-phone text-danger" style="font-size:1.5rem;"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">Mobile App</h5>
                            <small class="text-muted">Cross-platform mobile</small>
                        </div>
                    </div>
                    <p class="card-text text-muted">Flutter + Firebase + GCP. Cross-platform iOS/Android with real-time sync, push notifications, and analytics.</p>
                    <div class="mb-3">
                        <span class="badge bg-light text-dark me-1">Dart</span>
                        <span class="badge bg-light text-dark me-1">Flutter</span>
                        <span class="badge bg-light text-dark me-1">Firebase</span>
                        <span class="badge bg-light text-dark me-1">GCP</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-layers me-1"></i>BLoC Pattern</small>
                        <button class="btn btn-primary btn-sm" onclick="useKit('mobile-flutter')">
                            <i class="bi bi-arrow-right me-1"></i>Use This
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Custom / Blank -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-dashed kit-card" data-category="">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <i class="bi bi-plus-circle text-muted" style="font-size:3rem;"></i>
                    <h5 class="mt-3">Start from Scratch</h5>
                    <p class="text-muted">Build a custom project configuration from the ground up</p>
                    <a href="/Projects/Create" class="btn btn-outline-secondary btn-sm mx-auto" style="width:fit-content;">
                        <i class="bi bi-tools me-1"></i>Custom Setup
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Kit Preview Modal -->
    <div class="modal fade" id="kitPreviewModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Kit Preview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#previewTech">Tech Stack</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#previewArch">Architecture</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#previewWorkflow">Workflow</a>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="previewTech">
                            <div id="previewTechContent"></div>
                        </div>
                        <div class="tab-pane fade" id="previewArch">
                            <div id="previewArchContent"></div>
                        </div>
                        <div class="tab-pane fade" id="previewWorkflow">
                            <div id="previewWorkflowContent"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirmUseKit">
                        <i class="bi bi-check-lg me-1"></i>Use This Kit
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .border-dashed { border-style: dashed !important; border-width: 2px !important; }
    .kit-card { transition: transform 0.15s, box-shadow 0.15s; cursor: pointer; }
    .kit-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,.1); }
</style>
<script>
    document.getElementById('searchKits').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.kit-card').forEach(card => {
            card.closest('.col-lg-4').style.display =
                card.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    document.getElementById('categoryFilter').addEventListener('change', function() {
        const cat = this.value;
        document.querySelectorAll('.kit-card').forEach(card => {
            card.closest('.col-lg-4').style.display =
                !cat || card.dataset.category === cat ? '' : 'none';
        });
    });

    function useKit(kitId) {
        window.location.href = `/Projects/Create?starterKit=${kitId}`;
    }
</script>
}
