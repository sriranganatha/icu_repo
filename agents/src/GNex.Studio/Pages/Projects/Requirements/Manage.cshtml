@page
@{
    ViewData["Title"] = "Manage Requirements";
}

<div class="container-fluid px-4">
    <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Projects">Projects</a></li><li class="breadcrumb-item" id="bcProj">Project</li><li class="breadcrumb-item active">Requirements</li></ol></nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-list-check me-2"></i>Requirements Management</h2>
        <div>
            <a class="btn btn-outline-primary me-2" id="linkInput" href="#"><i class="bi bi-plus-lg me-1"></i>Add Requirements</a>
            <button class="btn btn-primary" onclick="generateBrd()"><i class="bi bi-file-earmark-richtext me-1"></i>Generate BRD</button>
        </div>
    </div>

    <!-- Stats -->
    <div class="row mb-4">
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Total</h6><h3 id="statTotal">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Functional</h6><h3 id="statFunc">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Non-Func</h6><h3 id="statNonFunc">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Enriched</h6><h3 id="statEnriched" class="text-success">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Pending</h6><h3 id="statPending" class="text-warning">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Coverage</h6><h3 id="statCoverage">0%</h3></div></div></div>
    </div>

    <div class="row">
        <!-- Filters -->
        <div class="col-md-3">
            <div class="card"><div class="card-body">
                <h6>Filters</h6>
                <div class="mb-3"><label class="form-label small">Search</label><input class="form-control form-control-sm" id="search" oninput="renderReqs()"></div>
                <div class="mb-3"><label class="form-label small">Type</label>
                    <select class="form-select form-select-sm" id="filterType" onchange="renderReqs()"><option value="">All</option><option>functional</option><option>non_functional</option><option>technical</option><option>business_rule</option><option>constraint</option></select></div>
                <div class="mb-3"><label class="form-label small">Priority</label>
                    <select class="form-select form-select-sm" id="filterPri" onchange="renderReqs()"><option value="">All</option><option>critical</option><option>high</option><option>medium</option><option>low</option></select></div>
                <div class="mb-3"><label class="form-label small">Status</label>
                    <select class="form-select form-select-sm" id="filterStatus" onchange="renderReqs()"><option value="">All</option><option>raw</option><option>enriched</option><option>approved</option><option>rejected</option></select></div>
            </div></div>

            <div class="card mt-3"><div class="card-body">
                <h6>Traceability</h6>
                <div class="small text-muted">
                    <div class="d-flex justify-content-between mb-1"><span>Linked to Stories</span><span id="traceStories">0</span></div>
                    <div class="d-flex justify-content-between mb-1"><span>Linked to BRD</span><span id="traceBrd">0</span></div>
                    <div class="d-flex justify-content-between"><span>Orphaned</span><span id="traceOrphan" class="text-danger">0</span></div>
                </div>
            </div></div>
        </div>

        <!-- Requirements List -->
        <div class="col-md-9">
            <div class="card"><div class="card-body p-0">
                <div class="table-responsive"><table class="table table-hover mb-0">
                    <thead><tr><th style="width:50px">#</th><th>Requirement</th><th>Type</th><th>Priority</th><th>Status</th><th>Enriched</th><th></th></tr></thead>
                    <tbody id="reqsBody"></tbody>
                </table></div>
            </div></div>
        </div>
    </div>
</div>

<!-- Requirement Detail Modal -->
<div class="modal fade" id="reqModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="reqModalTitle">Requirement Detail</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tabRaw">Raw</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabEnrich">Enriched</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabTrace">Traceability</a></li>
        </ul>
        <div class="tab-content">
            <div class="tab-pane active" id="tabRaw"><div id="rawDetail"></div></div>
            <div class="tab-pane" id="tabEnrich"><div id="enrichDetail"></div></div>
            <div class="tab-pane" id="tabTrace"><div id="traceDetail"></div></div>
        </div>
    </div>
</div></div></div>

@section Scripts {
<script>
    const params = new URLSearchParams(window.location.search);
    const projectId = params.get('projectId');
    let requirements = [];

    async function load() {
        if (!projectId) { window.location.href = '/Projects'; return; }
        document.getElementById('linkInput').href = `/Projects/Requirements/Input?projectId=${projectId}`;
        const proj = await fetch(`/api/projects/${encodeURIComponent(projectId)}`).then(r=>r.json());
        document.getElementById('bcProj').innerHTML = `<a href="/Projects">${esc(proj.name)}</a>`;
        // TODO: load requirements from API once endpoint exists
        requirements = [];
        renderStats();
        renderReqs();
    }

    function renderStats() {
        document.getElementById('statTotal').textContent = requirements.length;
        document.getElementById('statFunc').textContent = requirements.filter(r=>r.type==='functional').length;
        document.getElementById('statNonFunc').textContent = requirements.filter(r=>r.type==='non_functional').length;
        document.getElementById('statEnriched').textContent = requirements.filter(r=>r.status==='enriched').length;
        document.getElementById('statPending').textContent = requirements.filter(r=>r.status==='raw').length;
    }

    function renderReqs() {
        const q = document.getElementById('search').value.toLowerCase();
        const ft = document.getElementById('filterType').value;
        const fp = document.getElementById('filterPri').value;
        const fs = document.getElementById('filterStatus').value;
        let filtered = requirements.filter(r =>
            (!q || r.content.toLowerCase().includes(q)) &&
            (!ft || r.type === ft) &&
            (!fp || r.priority === fp) &&
            (!fs || r.status === fs)
        );
        document.getElementById('reqsBody').innerHTML = filtered.map((r,i) => `
            <tr onclick="openReq('${r.id}')" style="cursor:pointer">
                <td>${i+1}</td><td>${esc(r.content?.substring(0,80))}...</td>
                <td><span class="badge bg-light text-dark">${esc(r.type)}</span></td>
                <td><span class="badge bg-${priColor(r.priority)}">${esc(r.priority)}</span></td>
                <td><span class="badge bg-${statusColor(r.status)}">${esc(r.status)}</span></td>
                <td>${r.isEnriched ? '<i class="bi bi-check-circle text-success"></i>' : '<i class="bi bi-circle text-muted"></i>'}</td>
                <td><button class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></button></td>
            </tr>
        `).join('') || '<tr><td colspan="7" class="text-center text-muted py-5">No requirements yet. <a href="' + `/Projects/Requirements/Input?projectId=${projectId}` + '">Add some.</a></td></tr>';
    }

    function openReq(id) {
        const r = requirements.find(x => x.id === id);
        if (!r) return;
        document.getElementById('reqModalTitle').textContent = `REQ-${r.sequenceNumber || '?'}`;
        document.getElementById('rawDetail').innerHTML = `<p>${esc(r.content)}</p><small class="text-muted">Source: ${esc(r.source)} | Created: ${new Date(r.createdAt).toLocaleString()}</small>`;
        new bootstrap.Modal(document.getElementById('reqModal')).show();
    }

    function generateBrd() { window.location.href = `/Brd?projectId=${projectId}`; }
    function priColor(p) { return { critical:'danger', high:'warning', medium:'info', low:'secondary' }[p] || 'secondary'; }
    function statusColor(s) { return { raw:'secondary', enriched:'success', approved:'primary', rejected:'danger' }[s] || 'secondary'; }
    function esc(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }

    load();
</script>
}
