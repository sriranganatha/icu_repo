@page
@{
    ViewData["Title"] = "Test Results";
}

<div class="container-fluid px-4">
    <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Projects">Projects</a></li><li class="breadcrumb-item" id="bcProj">Project</li><li class="breadcrumb-item active">Testing</li></ol></nav>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-check2-square me-2"></i>Test Results</h2>
        <button class="btn btn-primary" onclick="runTests()"><i class="bi bi-play-fill me-1"></i>Run Tests</button>
    </div>

    <!-- Summary -->
    <div class="row mb-4">
        <div class="col-md-2"><div class="card text-bg-success"><div class="card-body py-2 text-center"><h6 class="mb-0">Passed</h6><h3 id="statPassed">0</h3></div></div></div>
        <div class="col-md-2"><div class="card text-bg-danger"><div class="card-body py-2 text-center"><h6 class="mb-0">Failed</h6><h3 id="statFailed">0</h3></div></div></div>
        <div class="col-md-2"><div class="card text-bg-warning"><div class="card-body py-2 text-center"><h6 class="mb-0">Skipped</h6><h3 id="statSkipped">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Total</h6><h3 id="statTotal">0</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Coverage</h6><h3 id="statCoverage">0%</h3></div></div></div>
        <div class="col-md-2"><div class="card"><div class="card-body py-2 text-center"><h6 class="text-muted mb-0">Duration</h6><h3 id="statDuration">-</h3></div></div></div>
    </div>

    <div class="row">
        <!-- Test Suites -->
        <div class="col-md-4">
            <div class="card"><div class="card-header py-2"><h6 class="mb-0">Test Suites</h6></div>
            <div class="card-body p-0" style="max-height:400px;overflow-y:auto"><div class="list-group list-group-flush" id="suiteList"></div></div></div>

            <!-- Coverage Heatmap -->
            <div class="card mt-3"><div class="card-header py-2"><h6 class="mb-0">Coverage Heatmap</h6></div>
            <div class="card-body">
                <div class="d-flex gap-1 flex-wrap" id="coverageHeatmap"></div>
                <div class="d-flex gap-2 mt-2 small">
                    <span><span class="badge" style="background:#dc3545">&nbsp;</span> &lt;50%</span>
                    <span><span class="badge" style="background:#ffc107">&nbsp;</span> 50-80%</span>
                    <span><span class="badge" style="background:#198754">&nbsp;</span> &gt;80%</span>
                </div>
            </div></div>
        </div>

        <!-- Test Results -->
        <div class="col-md-8">
            <div class="card"><div class="card-header d-flex justify-content-between">
                <h6 class="mb-0">Test Results</h6>
                <div>
                    <select class="form-select form-select-sm d-inline-block" style="width:auto" id="resultFilter" onchange="renderResults()">
                        <option value="">All</option><option value="passed">Passed</option><option value="failed">Failed</option><option value="skipped">Skipped</option>
                    </select>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height:500px;overflow-y:auto">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light sticky-top"><tr><th></th><th>Test Name</th><th>Suite</th><th>Duration</th><th></th></tr></thead>
                        <tbody id="resultBody"></tbody>
                    </table>
                </div>
            </div></div>
        </div>
    </div>
</div>

<!-- Test Detail Modal -->
<div class="modal fade" id="testModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title" id="testTitle">Test Detail</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <div class="mb-3" id="testInfo"></div>
        <h6>Output</h6><pre class="bg-dark text-light p-3 rounded small" id="testOutput" style="max-height:300px;overflow-y:auto;"></pre>
        <div id="testError" class="d-none"><h6>Error</h6><div class="alert alert-danger small" id="testErrorMsg"></div><pre class="bg-light p-2 small" id="testErrorStack" style="max-height:200px;overflow-y:auto;"></pre></div>
    </div>
</div></div></div>

@section Scripts {
<script>
    const params = new URLSearchParams(window.location.search);
    const projectId = params.get('projectId');
    let testResults = [], suites = [], coverage = {};

    async function load() {
        if (!projectId) { window.location.href = '/Projects'; return; }
        const proj = await fetch(`/api/projects/${encodeURIComponent(projectId)}`).then(r=>r.json());
        document.getElementById('bcProj').innerHTML = `<a href="/Projects">${esc(proj.name)}</a>`;
        // Load quality reports which contain test results
        try {
            const reports = await fetch(`/api/projects/${encodeURIComponent(projectId)}/quality-reports`).then(r=>r.ok?r.json():[]);
            if (reports.length) {
                const latest = reports[0];
                testResults = latest.testResults || [];
                suites = latest.testSuites || [];
                coverage = latest.coverage || {};
            }
        } catch(e) {}
        renderAll();
    }

    function renderAll() {
        renderStats();
        renderSuites();
        renderResults();
        renderCoverage();
    }

    function renderStats() {
        const passed = testResults.filter(t=>t.status==='passed').length;
        const failed = testResults.filter(t=>t.status==='failed').length;
        const skipped = testResults.filter(t=>t.status==='skipped').length;
        document.getElementById('statPassed').textContent = passed;
        document.getElementById('statFailed').textContent = failed;
        document.getElementById('statSkipped').textContent = skipped;
        document.getElementById('statTotal').textContent = testResults.length;
        document.getElementById('statCoverage').textContent = coverage.lineCoverage ? `${coverage.lineCoverage}%` : '0%';
    }

    function renderSuites() {
        document.getElementById('suiteList').innerHTML = suites.map(s => {
            const tests = testResults.filter(t=>t.suite===s.name);
            const passed = tests.filter(t=>t.status==='passed').length;
            return `<div class="list-group-item d-flex justify-content-between" style="cursor:pointer" onclick="filterBySuite('${esc(s.name)}')">
                <span>${esc(s.name)}</span><span><span class="badge bg-success">${passed}</span>/<span class="badge bg-secondary">${tests.length}</span></span></div>`;
        }).join('') || '<div class="list-group-item text-muted text-center small">No test suites</div>';
    }

    function renderResults() {
        const filter = document.getElementById('resultFilter').value;
        const filtered = testResults.filter(t => !filter || t.status === filter);
        document.getElementById('resultBody').innerHTML = filtered.map(t => `
            <tr onclick="openTest('${t.id}')" style="cursor:pointer">
                <td><i class="bi bi-${t.status==='passed'?'check-circle-fill text-success':t.status==='failed'?'x-circle-fill text-danger':'dash-circle text-warning'}"></i></td>
                <td class="small">${esc(t.name)}</td><td class="small text-muted">${esc(t.suite||'')}</td>
                <td class="small">${t.durationMs ? `${t.durationMs}ms` : '-'}</td>
                <td><button class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></button></td>
            </tr>
        `).join('') || '<tr><td colspan="5" class="text-center text-muted py-5">No test results. Run agents to generate and execute tests.</td></tr>';
    }

    function renderCoverage() {
        const files = coverage.files || [];
        document.getElementById('coverageHeatmap').innerHTML = files.map(f => {
            const pct = f.lineCoverage || 0;
            const color = pct >= 80 ? '#198754' : pct >= 50 ? '#ffc107' : '#dc3545';
            return `<div title="${esc(f.name)}: ${pct}%" style="width:24px;height:24px;background:${color};border-radius:3px;cursor:pointer" onclick="alert('${esc(f.name)}: ${pct}% coverage')"></div>`;
        }).join('') || '<span class="text-muted small">No coverage data</span>';
    }

    function openTest(id) {
        const t = testResults.find(x=>x.id===id);
        if (!t) return;
        document.getElementById('testTitle').textContent = t.name;
        document.getElementById('testInfo').innerHTML = `<span class="badge bg-${t.status==='passed'?'success':'danger'}">${esc(t.status)}</span> <span class="text-muted ms-2">${t.durationMs?t.durationMs+'ms':''}</span>`;
        document.getElementById('testOutput').textContent = t.output || 'No output';
        if (t.errorMessage) { document.getElementById('testError').classList.remove('d-none'); document.getElementById('testErrorMsg').textContent = t.errorMessage; document.getElementById('testErrorStack').textContent = t.stackTrace || ''; }
        else { document.getElementById('testError').classList.add('d-none'); }
        new bootstrap.Modal(document.getElementById('testModal')).show();
    }

    function filterBySuite(name) { /* could set filter */ }
    function runTests() { alert('Test execution will be triggered via the Testing Agent.'); }
    function esc(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }

    load();
</script>
}
