@page
@model GNex.Studio.Pages.Analytics.TuningModel
@{ ViewData["Title"] = "Auto-Tuning"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-sliders me-2"></i>Auto-Tuning Dashboard</h2>
            <p class="text-muted mb-0">AI-driven optimization of agent routing, prompts, and estimation parameters</p>
        </div>
        <div class="d-flex gap-2">
            <div class="form-check form-switch pt-2">
                <input class="form-check-input" type="checkbox" id="autoTuneEnabled" checked>
                <label class="form-check-label" for="autoTuneEnabled">Auto-Tune Active</label>
            </div>
            <button class="btn btn-outline-primary" onclick="runTuningCycle()">
                <i class="bi bi-arrow-repeat me-1"></i>Run Now
            </button>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-warning mb-1"><i class="bi bi-gear-wide-connected" style="font-size:1.5rem;"></i></div>
                    <h4 class="mb-0">12</h4>
                    <small class="text-muted">Tuning Decisions (30d)</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-success mb-1"><i class="bi bi-graph-up-arrow" style="font-size:1.5rem;"></i></div>
                    <h4 class="mb-0">+18%</h4>
                    <small class="text-muted">Success Rate Improvement</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-info mb-1"><i class="bi bi-lightning" style="font-size:1.5rem;"></i></div>
                    <h4 class="mb-0">-23%</h4>
                    <small class="text-muted">Avg Response Time</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-danger mb-1"><i class="bi bi-currency-dollar" style="font-size:1.5rem;"></i></div>
                    <h4 class="mb-0">-$42</h4>
                    <small class="text-muted">Monthly Cost Savings</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Model Routing -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-signpost-2 me-2"></i>Model Routing Decisions</span>
                    <span class="badge bg-primary">Active</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Agent</th>
                                    <th>Previous Model</th>
                                    <th></th>
                                    <th>Current Model</th>
                                    <th>Reason</th>
                                    <th>Impact</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Code Quality</td>
                                    <td><span class="badge bg-secondary">gemini-2.0-flash</span></td>
                                    <td><i class="bi bi-arrow-right text-primary"></i></td>
                                    <td><span class="badge bg-primary">gemini-2.5-pro</span></td>
                                    <td><small class="text-muted">Failure rate &gt; 15%</small></td>
                                    <td><span class="text-success">+22% accuracy</span></td>
                                </tr>
                                <tr>
                                    <td>Documentation</td>
                                    <td><span class="badge bg-secondary">gemini-2.5-pro</span></td>
                                    <td><i class="bi bi-arrow-right text-primary"></i></td>
                                    <td><span class="badge bg-primary">gemini-2.0-flash</span></td>
                                    <td><small class="text-muted">Great results at lower cost</small></td>
                                    <td><span class="text-success">-40% cost</span></td>
                                </tr>
                                <tr>
                                    <td>Testing</td>
                                    <td><span class="badge bg-secondary">gemini-2.0-flash</span></td>
                                    <td><i class="bi bi-arrow-right text-warning"></i></td>
                                    <td><span class="badge bg-warning text-dark">gemini-2.5-pro</span></td>
                                    <td><small class="text-muted">Complex test generation</small></td>
                                    <td><span class="text-success">+35% coverage</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Prompt Optimization -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-chat-text me-2"></i>Prompt Optimization</span>
                    <span class="badge bg-success">3 promoted</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Agent</th>
                                    <th>Prompt Version</th>
                                    <th>Success Rate</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Architecture</td>
                                    <td>v3 → v4</td>
                                    <td>
                                        <span class="text-muted">v3: 78%</span>
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <span class="text-success fw-bold">v4: 91%</span>
                                    </td>
                                    <td><span class="badge bg-success">Promoted</span></td>
                                    <td><button class="btn btn-outline-warning btn-sm" title="Rollback"><i class="bi bi-arrow-counterclockwise"></i></button></td>
                                </tr>
                                <tr>
                                    <td>Requirements</td>
                                    <td>v2 → v3</td>
                                    <td>
                                        <span class="text-muted">v2: 85%</span>
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <span class="text-success fw-bold">v3: 92%</span>
                                    </td>
                                    <td><span class="badge bg-success">Promoted</span></td>
                                    <td><button class="btn btn-outline-warning btn-sm" title="Rollback"><i class="bi bi-arrow-counterclockwise"></i></button></td>
                                </tr>
                                <tr>
                                    <td>Review</td>
                                    <td>v5 (testing)</td>
                                    <td>
                                        <span class="text-muted">v4: 88%</span>
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <span class="text-primary">v5: 87%</span>
                                    </td>
                                    <td><span class="badge bg-info">A/B Test</span></td>
                                    <td><button class="btn btn-outline-danger btn-sm" title="Reject"><i class="bi bi-x-lg"></i></button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estimation Tuning -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-calculator me-2"></i>Estimation Accuracy
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <small>Story Points: predicted vs actual</small>
                            <small class="text-muted">±1.2 avg deviation</small>
                        </div>
                        <div class="progress" style="height:20px;">
                            <div class="progress-bar bg-success" style="width:65%;">Under-estimate 35%</div>
                            <div class="progress-bar bg-info" style="width:20%;">Accurate 20%</div>
                            <div class="progress-bar bg-warning" style="width:15%;">Over-estimate 15%</div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <small>Cycle Time: predicted vs actual</small>
                            <small class="text-muted">±0.8 days avg</small>
                        </div>
                        <div class="progress" style="height:20px;">
                            <div class="progress-bar bg-success" style="width:55%;">Under 30%</div>
                            <div class="progress-bar bg-info" style="width:30%;">Accurate 30%</div>
                            <div class="progress-bar bg-warning" style="width:15%;">Over 15%</div>
                        </div>
                    </div>
                    <div class="alert alert-info small mb-0">
                        <i class="bi bi-lightbulb me-1"></i>
                        Recommendation: Increase complexity multiplier by 1.15x for stories with &gt;3 dependencies
                    </div>
                </div>
            </div>
        </div>

        <!-- Tuning History -->
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-clock-history me-2"></i>Recent Tuning Actions
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" style="max-height:300px; overflow-y:auto;">
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong class="small">Model swap: Documentation</strong>
                                <small class="text-muted">2h ago</small>
                            </div>
                            <small class="text-muted">gemini-2.5-pro → gemini-2.0-flash (cost optimization)</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong class="small">Prompt promoted: Architecture v4</strong>
                                <small class="text-muted">6h ago</small>
                            </div>
                            <small class="text-muted">Success rate improved from 78% to 91%</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong class="small">Estimation formula updated</strong>
                                <small class="text-muted">1d ago</small>
                            </div>
                            <small class="text-muted">Complexity multiplier adjusted: 1.0 → 1.15 for high-dependency stories</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong class="small">Model swap: Code Quality</strong>
                                <small class="text-muted">2d ago</small>
                            </div>
                            <small class="text-muted">gemini-2.0-flash → gemini-2.5-pro (accuracy improvement)</small>
                        </div>
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <strong class="small">A/B test started: Review v5</strong>
                                <small class="text-muted">3d ago</small>
                            </div>
                            <small class="text-muted">Testing new prompt variant with structured output format</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Manual Override -->
    <div class="card mt-4">
        <div class="card-header">
            <i class="bi bi-hand-index me-2"></i>Manual Overrides
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Agent</label>
                    <select class="form-select" id="overrideAgent">
                        <option value="">Select agent...</option>
                        <option>Architecture</option>
                        <option>Code Quality</option>
                        <option>Review</option>
                        <option>Testing</option>
                        <option>Documentation</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Parameter</label>
                    <select class="form-select" id="overrideParam">
                        <option value="">Select parameter...</option>
                        <option value="model">LLM Model</option>
                        <option value="prompt">Prompt Version</option>
                        <option value="temperature">Temperature</option>
                        <option value="maxTokens">Max Tokens</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Value</label>
                    <input type="text" class="form-control" id="overrideValue" placeholder="New value" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-warning w-100" onclick="applyOverride()">
                        <i class="bi bi-pencil me-1"></i>Apply Override
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function runTuningCycle() {
        // Placeholder — POST /api/tuning/run
    }

    function applyOverride() {
        const agent = document.getElementById('overrideAgent').value;
        const param = document.getElementById('overrideParam').value;
        const value = document.getElementById('overrideValue').value;
        if (!agent || !param || !value) return;
        // Placeholder — POST /api/tuning/override
    }
</script>
}
