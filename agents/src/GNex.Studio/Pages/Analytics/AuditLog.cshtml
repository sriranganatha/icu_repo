@page
@{
    ViewData["Title"] = "Audit Log";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-journal-text me-2"></i>Audit Log</h2>
        <button class="btn btn-outline-secondary" onclick="exportLog()"><i class="bi bi-download me-1"></i>Export</button>
    </div>

    <!-- Filters -->
    <div class="row mb-3">
        <div class="col-md-3"><input class="form-control" id="search" placeholder="Search events..." oninput="renderLog()"></div>
        <div class="col-md-2"><select class="form-select" id="entityFilter" onchange="renderLog()"><option value="">All Entities</option><option>Project</option><option>Agent</option><option>Template</option><option>Workflow</option><option>User</option><option>Config</option></select></div>
        <div class="col-md-2"><select class="form-select" id="actionFilter" onchange="renderLog()"><option value="">All Actions</option><option>Create</option><option>Update</option><option>Delete</option><option>Execute</option><option>Approve</option><option>Login</option></select></div>
        <div class="col-md-2"><select class="form-select" id="projectFilter" onchange="renderLog()"><option value="">All Projects</option></select></div>
        <div class="col-md-2"><input class="form-control" id="dateFilter" type="date" onchange="renderLog()"></div>
        <div class="col-md-1"><button class="btn btn-outline-secondary w-100" onclick="clearFilters()"><i class="bi bi-x-lg"></i></button></div>
    </div>

    <!-- Stats -->
    <div class="row mb-3">
        <div class="col"><span class="badge bg-primary" id="eventCount">0 events</span></div>
    </div>

    <!-- Log Table -->
    <div class="card"><div class="card-body p-0">
        <div class="table-responsive" style="max-height:600px;overflow-y:auto">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light sticky-top"><tr><th style="width:160px">Timestamp</th><th>User</th><th>Action</th><th>Entity</th><th>Details</th><th>Project</th><th></th></tr></thead>
                <tbody id="logBody"></tbody>
            </table>
        </div>
    </div></div>

    <nav class="mt-3"><ul class="pagination justify-content-center" id="pagination"></ul></nav>
</div>

<!-- Event Detail Modal -->
<div class="modal fade" id="eventModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title">Event Detail</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <div id="eventDetail"></div>
        <h6 class="mt-3">Changes</h6>
        <pre class="bg-light p-3 rounded small" id="eventChanges" style="max-height:300px;overflow-y:auto"></pre>
    </div>
</div></div></div>

@section Scripts {
<script>
    let events = [], page = 1, pageSize = 50;

    async function load() {
        const projects = await fetch('/api/projects').then(r=>r.json());
        document.getElementById('projectFilter').innerHTML = '<option value="">All Projects</option>' + projects.map(p=>`<option value="${p.id}">${esc(p.name)}</option>`).join('');
        // Audit events will come from existing AuditEvent entity
        events = [];
        renderLog();
    }

    function renderLog() {
        const q = document.getElementById('search').value.toLowerCase();
        const ef = document.getElementById('entityFilter').value;
        const af = document.getElementById('actionFilter').value;
        const pf = document.getElementById('projectFilter').value;
        const df = document.getElementById('dateFilter').value;
        let filtered = events.filter(e =>
            (!q || JSON.stringify(e).toLowerCase().includes(q)) &&
            (!ef || e.entityType === ef) &&
            (!af || e.action === af) &&
            (!pf || e.projectId === pf) &&
            (!df || (e.timestamp||'').startsWith(df))
        );
        document.getElementById('eventCount').textContent = `${filtered.length} events`;
        const start = (page-1)*pageSize;
        const paged = filtered.slice(start, start+pageSize);
        document.getElementById('logBody').innerHTML = paged.map(e => `
            <tr onclick="openEvent('${e.id}')" style="cursor:pointer">
                <td class="small text-muted">${e.timestamp ? new Date(e.timestamp).toLocaleString() : ''}</td>
                <td>${esc(e.userId||'System')}</td>
                <td><span class="badge bg-${actionColor(e.action)}">${esc(e.action)}</span></td>
                <td>${esc(e.entityType)}</td>
                <td class="small">${esc(e.summary||'')}</td>
                <td class="small">${esc(e.projectName||'')}</td>
                <td><button class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></button></td>
            </tr>
        `).join('') || '<tr><td colspan="7" class="text-center text-muted py-5">No audit events recorded yet</td></tr>';
    }

    function openEvent(id) {
        const e = events.find(x=>x.id===id);
        if (!e) return;
        document.getElementById('eventDetail').innerHTML = `<table class="table table-sm"><tbody>
            <tr><th>Timestamp</th><td>${new Date(e.timestamp).toLocaleString()}</td></tr>
            <tr><th>User</th><td>${esc(e.userId)}</td></tr><tr><th>Action</th><td>${esc(e.action)}</td></tr>
            <tr><th>Entity</th><td>${esc(e.entityType)} — ${esc(e.entityId)}</td></tr>
            <tr><th>IP</th><td>${esc(e.ipAddress||'-')}</td></tr>
        </tbody></table>`;
        document.getElementById('eventChanges').textContent = e.changes ? JSON.stringify(JSON.parse(e.changes), null, 2) : 'No change data';
        new bootstrap.Modal(document.getElementById('eventModal')).show();
    }

    function clearFilters() { ['search','entityFilter','actionFilter','projectFilter','dateFilter'].forEach(id=>document.getElementById(id).value=''); renderLog(); }
    function exportLog() { alert('Audit log export to CSV — to be implemented.'); }
    function actionColor(a) { return { Create:'success', Update:'info', Delete:'danger', Execute:'primary', Approve:'warning', Login:'secondary' }[a] || 'secondary'; }
    function esc(s) { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }

    load();
</script>
}
