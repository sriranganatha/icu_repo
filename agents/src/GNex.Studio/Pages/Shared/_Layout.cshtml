    <!-- ═══ Global Message Box (replaces native alert / confirm / prompt) ═══ -->
    <div class="modal fade" id="gnMsgBox" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius:.75rem; overflow:hidden;">
                <div class="modal-header py-2 border-0" id="gnMsgHeader">
                    <div class="d-flex align-items-center gap-2">
                        <span id="gnMsgIcon" class="fs-4"></span>
                        <h5 class="modal-title mb-0 fw-bold" id="gnMsgTitle"></h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" id="gnMsgClose"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0" id="gnMsgBody"></p>
                    <div id="gnMsgInputGroup" style="display:none;" class="mt-3">
                        <label class="form-label fw-semibold small text-muted" id="gnMsgInputLabel"></label>
                        <input type="text" class="form-control" id="gnMsgInput" autocomplete="off">
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0" id="gnMsgFooter">
                    <button class="btn" id="gnMsgCancel" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn" id="gnMsgOk">OK</button>
                </div>
            </div>
        </div>
    </div>
    <script>
    /**
     * Professional message-box API — drop-in replacement for alert / confirm / prompt.
     *
     * Usage:
     *   await msgBox.alert('Title', 'Body text');                        // info alert
     *   await msgBox.success('Done', 'BRD approved.');                   // green
     *   await msgBox.error('Oops', 'Something went wrong.');             // red
     *   await msgBox.warning('Heads up', 'This cannot be undone.');      // amber
     *   const ok   = await msgBox.confirm('Delete?', 'Are you sure?');   // true / false
     *   const val  = await msgBox.prompt('Reason', 'Enter a reason:', { required: true, placeholder: '...' });
     *                                                                     // string | null
     */
    window.msgBox = (() => {
        const el    = id => document.getElementById(id);
        const modal = () => bootstrap.Modal.getOrCreateInstance(el('gnMsgBox'));

        // Theme map: [headerBg, iconHtml, okBtnClass]
        const themes = {
            info:    ['linear-gradient(135deg,#1a237e,#0d47a1)', '<i class="bi bi-info-circle-fill text-white"></i>',    'btn-primary'],
            success: ['linear-gradient(135deg,#1b5e20,#2e7d32)', '<i class="bi bi-check-circle-fill text-white"></i>',   'btn-success'],
            error:   ['linear-gradient(135deg,#b71c1c,#c62828)', '<i class="bi bi-exclamation-triangle-fill text-white"></i>', 'btn-danger'],
            warning: ['linear-gradient(135deg,#e65100,#f57c00)', '<i class="bi bi-exclamation-circle-fill text-white"></i>',  'btn-warning'],
            confirm: ['linear-gradient(135deg,#1a237e,#0d47a1)', '<i class="bi bi-question-circle-fill text-white"></i>','btn-primary'],
            prompt:  ['linear-gradient(135deg,#1a237e,#0d47a1)', '<i class="bi bi-pencil-square text-white"></i>',       'btn-primary'],
        };

        function show(type, title, body, opts = {}) {
            return new Promise(resolve => {
                const [bg, icon, okCls] = themes[type] || themes.info;

                el('gnMsgHeader').style.background = bg;
                el('gnMsgIcon').innerHTML   = icon;
                el('gnMsgTitle').textContent = title;
                el('gnMsgTitle').className   = 'modal-title mb-0 fw-bold text-white';
                el('gnMsgBody').textContent  = body;
                el('gnMsgClose').className   = 'btn-close btn-close-white';

                // OK button
                const okBtn = el('gnMsgOk');
                okBtn.className = `btn ${okCls}`;
                okBtn.textContent = opts.okText || 'OK';

                // Cancel button
                const cancelBtn = el('gnMsgCancel');
                const showCancel = type === 'confirm' || type === 'prompt';
                cancelBtn.style.display = showCancel ? '' : 'none';
                cancelBtn.className = 'btn btn-outline-secondary';
                cancelBtn.textContent = opts.cancelText || 'Cancel';

                // Prompt input
                const inputGroup = el('gnMsgInputGroup');
                const input = el('gnMsgInput');
                if (type === 'prompt') {
                    inputGroup.style.display = '';
                    el('gnMsgInputLabel').textContent = opts.inputLabel || '';
                    input.value = opts.defaultValue || '';
                    input.placeholder = opts.placeholder || '';
                    input.type = opts.inputType || 'text';
                    setTimeout(() => input.focus(), 300);
                } else {
                    inputGroup.style.display = 'none';
                    input.value = '';
                }

                let resolved = false;
                const cleanup = () => {
                    okBtn.replaceWith(okBtn.cloneNode(true));
                    cancelBtn.replaceWith(cancelBtn.cloneNode(true));
                    el('gnMsgBox').removeEventListener('hidden.bs.modal', onHidden);
                };

                const finish = val => {
                    if (resolved) return;
                    resolved = true;
                    cleanup();
                    modal().hide();
                    resolve(val);
                };

                const onHidden = () => {
                    if (!resolved) { resolved = true; cleanup(); resolve(type === 'prompt' ? null : type === 'confirm' ? false : undefined); }
                };

                el('gnMsgOk').addEventListener('click', () => {
                    if (type === 'prompt') {
                        const v = input.value.trim();
                        if (opts.required && !v) { input.classList.add('is-invalid'); return; }
                        input.classList.remove('is-invalid');
                        finish(v || null);
                    } else if (type === 'confirm') {
                        finish(true);
                    } else {
                        finish(undefined);
                    }
                });

                el('gnMsgBox').addEventListener('hidden.bs.modal', onHidden);
                // Enter-key support
                if (type === 'prompt') {
                    input.onkeydown = e => { if (e.key === 'Enter') el('gnMsgOk').click(); };
                }

                modal().show();
            });
        }

        return {
            alert:   (title, body, opts) => show('info',    title, body, opts),
            success: (title, body, opts) => show('success', title, body, opts),
            error:   (title, body, opts) => show('error',   title, body, opts),
            warning: (title, body, opts) => show('warning', title, body, opts),
            confirm: (title, body, opts) => show('confirm', title, body, { okText: 'Yes', cancelText: 'No', ...opts }),
            prompt:  (title, body, opts) => show('prompt',  title, body, opts),
        };
    })();
    </script>
    <script>
        // ── Global Active Project Context ─────────────────────
        window.getActiveProjectId = () => localStorage.getItem('activeProjectId') || '';
        window.getActiveProjectName = () => localStorage.getItem('activeProjectName') || '';

        function setActiveProject(id) {
            const sel = document.getElementById('globalProjectSelector');
            const name = sel.options[sel.selectedIndex]?.text || '';
            if (id) {
                localStorage.setItem('activeProjectId', id);
                localStorage.setItem('activeProjectName', name);
            } else {
                localStorage.removeItem('activeProjectId');
                localStorage.removeItem('activeProjectName');
            }
            window.dispatchEvent(new CustomEvent('projectChanged', { detail: { id, name } }));
        }

        async function loadGlobalProjects() {
            try {
                const res = await fetch('/api/projects?take=100');
                if (!res.ok) return;
                const projects = await res.json();
                const sel = document.getElementById('globalProjectSelector');
                projects.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p.id;
                    opt.textContent = `${p.name} (${p.projectType || 'project'})`;
                    sel.appendChild(opt);
                });
                // Restore previous selection
                const saved = localStorage.getItem('activeProjectId');
                if (saved && [...sel.options].some(o => o.value === saved)) {
                    sel.value = saved;
                }
            } catch (e) { console.warn('Could not load projects for selector:', e); }
        }
        loadGlobalProjects();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>