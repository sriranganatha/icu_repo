@model GNex.Studio.Pages.AgentCardModel

<div class="card h-100 border-start border-3 agent-card-clickable" style="cursor:pointer;" onclick="openAgentDetail('@Model.AgentKey')">
    <div class="card-body pb-2">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-title mb-0">
                <i class="bi @Model.Icon me-1"></i> @Model.Name
            </h6>
            <span class="badge agent-status bg-secondary">Idle</span>
        </div>
        <p class="card-text text-muted" style="font-size:0.8rem;">@Model.Description</p>
        <div class="progress mb-2" style="height:4px;">
            <div class="progress-bar" role="progressbar" style="width:0%"></div>
        </div>
        <div class="d-flex justify-content-between" style="font-size:0.75rem;">
            <span>Artifacts: <strong class="agent-artifacts">0</strong></span>
            <span class="agent-message text-muted text-truncate ms-2" style="max-width:140px;">Waiting...</span>
        </div>
    </div>
</div>
