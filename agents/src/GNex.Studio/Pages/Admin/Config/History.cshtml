@page
@model GNex.Studio.Pages.Admin.Config.HistoryModel
@{ ViewData["Title"] = "Configuration History"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-clock-history me-2"></i>Configuration History</h2>
            <p class="text-muted mb-0">View and compare configuration snapshots across pipeline runs</p>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select" id="projectFilter" style="width:200px;">
                <option value="">All Projects</option>
            </select>
            <select class="form-select" id="typeFilter" style="width:180px;">
                <option value="">All Types</option>
                <option value="pipeline_start">Pipeline Start</option>
                <option value="manual">Manual</option>
                <option value="config_change">Config Change</option>
            </select>
        </div>
    </div>

    <div class="row">
        <!-- Timeline -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Snapshots</span>
                    <span class="badge bg-secondary" id="snapshotCount">0</span>
                </div>
                <div class="card-body p-0">
                    <div id="snapshotTimeline" style="max-height:600px; overflow-y:auto;">
                        <div class="list-group list-group-flush">
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-clock-history" style="font-size:2rem;"></i>
                                <p class="mt-2">No snapshots found</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">Compare</div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-5">
                            <select class="form-select form-select-sm" id="compareLeft">
                                <option value="">Select snapshot...</option>
                            </select>
                        </div>
                        <div class="col-2 text-center pt-1">
                            <i class="bi bi-arrow-left-right"></i>
                        </div>
                        <div class="col-5">
                            <select class="form-select form-select-sm" id="compareRight">
                                <option value="">Select snapshot...</option>
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm w-100 mt-2" onclick="compareSnapshots()">
                        <i class="bi bi-file-diff me-1"></i>Compare
                    </button>
                </div>
            </div>
        </div>

        <!-- Detail / Diff Viewer -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header">
                    <ul class="nav nav-tabs card-header-tabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#viewTab">View</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#diffTab">Diff</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#rawTab">Raw JSON</a>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="viewTab">
                            <div id="configViewer">
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-eye" style="font-size:2rem;"></i>
                                    <p class="mt-2">Select a snapshot to view its configuration</p>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="diffTab">
                            <div id="diffViewer">
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-file-diff" style="font-size:2rem;"></i>
                                    <p class="mt-2">Select two snapshots to compare</p>
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="rawTab">
                            <pre id="rawJson" class="bg-dark text-light p-3 rounded" style="max-height:500px; overflow:auto;">
Select a snapshot to view raw JSON
                            </pre>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Snapshot Metadata -->
            <div class="card mt-3" id="snapshotMeta" style="display:none;">
                <div class="card-header">Snapshot Details</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <small class="text-muted">Snapshot ID</small>
                            <div id="metaId" class="fw-bold font-monospace small"></div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Created At</small>
                            <div id="metaCreated"></div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Trigger</small>
                            <div id="metaTrigger"></div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Type</small>
                            <span class="badge bg-info" id="metaType"></span>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Agent Run</small>
                            <div id="metaAgentRun" class="font-monospace small"></div>
                        </div>
                        <div class="col-md-4">
                            <small class="text-muted">Previous Snapshot</small>
                            <div id="metaPrevious" class="font-monospace small"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function loadSnapshots() {
        // Placeholder — fetch from /api/config/snapshots
    }

    function viewSnapshot(id) {
        document.getElementById('snapshotMeta').style.display = '';
        // Placeholder — fetch and render snapshot
    }

    function compareSnapshots() {
        const left = document.getElementById('compareLeft').value;
        const right = document.getElementById('compareRight').value;
        if (!left || !right) return;
        // Placeholder — fetch both and diff
    }

    loadSnapshots();
</script>
}
