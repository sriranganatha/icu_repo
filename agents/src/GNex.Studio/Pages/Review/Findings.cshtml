@page
@model GNex.Studio.Pages.Review.FindingsModel
@{
    ViewData["Title"] = "Review Findings";
}

<div class="container-fluid mt-3">
    <h3><i class="bi bi-shield-check"></i> Review Findings</h3>
    <p class="text-muted">Code review findings generated by the Review Agent — checked against requirements, security, and compliance rules.</p>

    <div class="row mb-3">
        <div class="col-auto">
            <select id="sevFilter" class="form-select form-select-sm" onchange="filterFindings()">
                <option value="">All Severities</option>
                <option value="Info">Info</option>
                <option value="Warning">Warning</option>
                <option value="Error">Error</option>
                <option value="Critical">Critical</option>
                <option value="SecurityViolation">Security Violation</option>
                <option value="ComplianceViolation">Compliance Violation</option>
            </select>
        </div>
        <div class="col-auto">
            <select id="catFilter" class="form-select form-select-sm" onchange="filterFindings()">
                <option value="">All Categories</option>
                <option value="Traceability">Traceability</option>
                <option value="MultiTenant">Multi-Tenant</option>
                <option value="Security">Security</option>
                <option value="Audit">Audit</option>
                <option value="Coverage">Coverage</option>
                <option value="Conventions">Conventions</option>
            </select>
        </div>
        <div class="col-auto">
            <span id="findingCount" class="badge bg-warning text-dark"></span>
        </div>
    </div>

    <div id="findingsList"></div>
</div>

@section Scripts {
    <script>
        let allFindings = [];

        async function loadFindings() {
            const res = await fetch('/api/pipeline/findings');
            allFindings = await res.json();
            filterFindings();
        }

        function filterFindings() {
            const sev = document.getElementById('sevFilter').value;
            const cat = document.getElementById('catFilter').value;
            let filtered = allFindings;
            if (sev) filtered = filtered.filter(f => f.severity === sev);
            if (cat) filtered = filtered.filter(f => f.category === cat);

            document.getElementById('findingCount').textContent = `${filtered.length} findings`;

            const sevColors = {
                Info: "info", Warning: "warning", Error: "danger",
                Critical: "danger", SecurityViolation: "danger", ComplianceViolation: "danger"
            };

            const html = filtered.map(f => `
                <div class="alert alert-${sevColors[f.severity] || 'secondary'} py-2 px-3 mb-2">
                    <div class="d-flex justify-content-between">
                        <strong>${f.category}</strong>
                        <span class="badge bg-${sevColors[f.severity] || 'secondary'}">${f.severity}</span>
                    </div>
                    <p class="mb-1">${f.message}</p>
                    ${f.suggestion ? `<small class="text-muted"><i class="bi bi-lightbulb me-1"></i>${f.suggestion}</small>` : ''}
                    ${f.filePath ? `<br/><small class="text-muted"><i class="bi bi-file-earmark me-1"></i>${f.filePath}</small>` : ''}
                </div>`).join('');

            document.getElementById('findingsList').innerHTML = html || '<p class="text-muted text-center mt-5">No findings yet. Run the pipeline first.</p>';
        }

        loadFindings();
    </script>
}
