@page
@{
    ViewData["Title"] = "Edit BRD";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-pencil-square me-2"></i>Edit BRD</h2>
        <a href="/Brd" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to BRD List</a>
    </div>

    <!-- BRD selector (shown when no brdId in URL) -->
    <div class="card mb-4" id="brdSelectorCard">
        <div class="card-header"><i class="bi bi-file-earmark-text me-1"></i>Select BRD Document</div>
        <div class="card-body">
            <div id="brdSelectorLoading" class="text-muted"><i class="bi bi-hourglass-split me-1"></i>Loading BRD documents...</div>
            <div id="brdSelectorList" class="row g-3" style="display:none;"></div>
            <div id="noBrds" class="text-center text-muted py-3" style="display:none;">
                <i class="bi bi-inbox fs-3"></i>
                <p class="mt-2 mb-0">No BRD documents found. <a href="/Brd">Create one first</a>.</p>
            </div>
        </div>
    </div>

    <!-- Active BRD header -->
    <div id="activeBrdBar" class="alert alert-primary d-flex justify-content-between align-items-center mb-3" style="display:none!important;">
        <div>
            <i class="bi bi-file-earmark-text-fill me-1"></i>
            <strong id="activeBrdTitle"></strong>
            <span class="badge ms-2" id="activeBrdType"></span>
            <span class="badge bg-info ms-1" id="activeSectionCount"></span>
            <span class="badge ms-1" id="activeBrdStatus"></span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" onclick="editBrdMeta()">
                <i class="bi bi-gear me-1"></i>Settings
            </button>
            <button class="btn btn-sm btn-outline-primary" onclick="changeBrd()">
                <i class="bi bi-arrow-repeat me-1"></i>Change BRD
            </button>
        </div>
    </div>

    <!-- BRD Metadata (collapsible) -->
    <div class="card mb-3" id="brdMetaCard" style="display:none;">
        <div class="card-header d-flex justify-content-between">
            <span><i class="bi bi-info-circle me-1"></i>BRD Details</span>
            <button class="btn btn-sm btn-outline-secondary" onclick="hideBrdMeta()"><i class="bi bi-x"></i></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Title</label>
                    <input type="text" class="form-control" id="metaTitle">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Description</label>
                    <input type="text" class="form-control" id="metaDescription">
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold">Custom AI Instructions</label>
                    <textarea class="form-control" id="metaInstructions" rows="2"
                              placeholder="e.g. Build BRD focused on UI and UX screens for patient registration"></textarea>
                </div>
                <div class="col-12">
                    <button class="btn btn-primary btn-sm" onclick="saveBrdMeta()">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- BRD Workflow Status Bar -->
    <div id="workflowBar" class="card mb-3" style="display:none;">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold">BRD Status:</span>
                    <div class="d-flex align-items-center gap-1" id="statusPipeline">
                        <span class="badge rounded-pill" id="stepDraft">Draft</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                        <span class="badge rounded-pill" id="stepEnriched">Enriched</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                        <span class="badge rounded-pill" id="stepInReview">In Review</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                        <span class="badge rounded-pill" id="stepApproved">Approved</span>
                    </div>
                    <span id="approvalInfo" class="text-muted small" style="display:none;"></span>
                </div>
                <div class="d-flex gap-2" id="workflowActions">
                    <button class="btn btn-sm btn-primary" id="btnSubmitReview" onclick="submitForReview()" style="display:none;">
                        <i class="bi bi-send me-1"></i>Submit for Review
                    </button>
                    <button class="btn btn-sm btn-success" id="btnApprove" onclick="approveBrd()" style="display:none;">
                        <i class="bi bi-check-circle me-1"></i>Approve
                    </button>
                    <button class="btn btn-sm btn-danger" id="btnReject" onclick="rejectBrd()" style="display:none;">
                        <i class="bi bi-x-circle me-1"></i>Reject
                    </button>
                    <button class="btn btn-sm btn-warning" id="btnRequestChanges" onclick="requestChanges()" style="display:none;">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Request Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Action bar -->
    <div id="actionBar" class="d-flex justify-content-between align-items-center mb-3" style="display:none;">
        <div class="d-flex gap-2">
            <button class="btn btn-success" id="btnSaveAll" onclick="saveAllSections()" disabled>
                <i class="bi bi-save me-1"></i>Save All Changes
            </button>
            <button class="btn btn-outline-secondary" id="btnCancelEdits" onclick="cancelEdits()" disabled>
                <i class="bi bi-x-circle me-1"></i>Cancel Edits
            </button>
            <button class="btn btn-primary" id="btnEnrich" onclick="enrichAllSections()">
                <i class="bi bi-stars me-1"></i>Enrich with AI
            </button>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" onclick="expandAll()">
                <i class="bi bi-arrows-expand me-1"></i>Expand All
            </button>
            <button class="btn btn-outline-primary" onclick="collapseAll()">
                <i class="bi bi-arrows-collapse me-1"></i>Collapse All
            </button>
        </div>
    </div>

    <!-- Sections editor -->
    <div id="sectionsContainer"></div>
</div>

@section Scripts {
<script>
    let selectedBrdId = null;
    let currentBrd = null;
    let loadedSections = [];
    let editedSections = {};

    // ── Init ──────────────────────────────────────────────
    (async function init() {
        const params = new URLSearchParams(window.location.search);
        const brdId = params.get('brdId');
        if (brdId) {
            selectedBrdId = brdId;
            await loadBrdDocument(brdId);
        } else {
            await loadBrdSelector();
        }
    })();

    // ── BRD Selector ─────────────────────────────────────
    async function loadBrdSelector() {
        document.getElementById('brdSelectorCard').style.display = '';
        document.getElementById('actionBar').style.display = 'none';
        document.getElementById('activeBrdBar').style.cssText = 'display:none!important';
        document.getElementById('workflowBar').style.display = 'none';
        document.getElementById('brdMetaCard').style.display = 'none';
        document.getElementById('sectionsContainer').innerHTML = '';

        try {
            const res = await fetch('/api/brd/documents');
            if (!res.ok) throw new Error('Failed to load');
            const docs = await res.json();

            document.getElementById('brdSelectorLoading').style.display = 'none';

            if (docs.length === 0) {
                document.getElementById('noBrds').style.display = '';
                return;
            }

            const list = document.getElementById('brdSelectorList');
            list.style.display = '';
            list.innerHTML = docs.map(d => `
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100" style="cursor:pointer"
                         onclick="selectBrd('${d.id}')">
                        <div class="card-body">
                            <h6 class="card-title mb-1">${escapeHtml(d.title)}</h6>
                            <span class="badge ${typeBadgeClass(d.brdType)}">${d.brdTypeDisplay}</span>
                            <span class="badge bg-info ms-1">${d.sectionCount} sections</span>
                            <span class="badge ${statusBadgeClass(d.status)} ms-1">${formatStatus(d.status)}</span>
                            <div class="text-muted small mt-2">${escapeHtml(d.projectName)}</div>
                        </div>
                    </div>
                </div>
            `).join('');
        } catch (e) {
            document.getElementById('brdSelectorLoading').innerHTML =
                '<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Error loading BRDs.</span>';
        }
    }

    async function selectBrd(brdId) {
        selectedBrdId = brdId;
        history.replaceState(null, '', `/Brd/Edit?brdId=${brdId}`);
        await loadBrdDocument(brdId);
    }

    function changeBrd() {
        selectedBrdId = null;
        currentBrd = null;
        editedSections = {};
        history.replaceState(null, '', '/Brd/Edit');
        loadBrdSelector();
    }

    // ── Load BRD Document ─────────────────────────────────
    async function loadBrdDocument(brdId) {
        try {
            const res = await fetch(`/api/brd/documents/${brdId}`);
            if (!res.ok) {
                document.getElementById('sectionsContainer').innerHTML =
                    '<div class="alert alert-warning">BRD document not found.</div>';
                return;
            }
            currentBrd = await res.json();
            selectedBrdId = currentBrd.id;

            showActiveBrd(currentBrd);
            updateWorkflowBar(currentBrd.status);
            await loadSections(brdId);
        } catch (e) {
            document.getElementById('sectionsContainer').innerHTML =
                '<div class="alert alert-danger">Error loading BRD: ' + e.message + '</div>';
        }
    }

    function showActiveBrd(brd) {
        document.getElementById('brdSelectorCard').style.display = 'none';
        const bar = document.getElementById('activeBrdBar');
        bar.style.cssText = '';
        document.getElementById('activeBrdTitle').textContent = brd.title;
        document.getElementById('activeBrdType').textContent = brd.brdTypeDisplay;
        document.getElementById('activeBrdType').className = `badge ms-2 ${typeBadgeClass(brd.brdType)}`;
        document.getElementById('activeSectionCount').textContent = `${brd.sectionCount} sections`;
    }

    // ── BRD Meta editing ──────────────────────────────────
    function editBrdMeta() {
        if (!currentBrd) return;
        document.getElementById('metaTitle').value = currentBrd.title;
        document.getElementById('metaDescription').value = currentBrd.description || '';
        document.getElementById('metaInstructions').value = currentBrd.instructions || '';
        document.getElementById('brdMetaCard').style.display = '';
    }

    function hideBrdMeta() {
        document.getElementById('brdMetaCard').style.display = 'none';
    }

    async function saveBrdMeta() {
        if (!selectedBrdId) return;
        const res = await fetch(`/api/brd/documents/${selectedBrdId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                title: document.getElementById('metaTitle').value.trim() || null,
                description: document.getElementById('metaDescription').value.trim() || null,
                instructions: document.getElementById('metaInstructions').value.trim() || null
            })
        });
        if (res.ok) {
            showToast('BRD details updated.');
            hideBrdMeta();
            await loadBrdDocument(selectedBrdId);
        } else {
            alert('Update failed.');
        }
    }

    // ── Section loading ───────────────────────────────────
    async function loadSections(brdId) {
        const res = await fetch(`/api/brd/documents/${brdId}/sections`);
        if (!res.ok) {
            document.getElementById('sectionsContainer').innerHTML =
                '<div class="alert alert-warning">Could not load sections.</div>';
            return;
        }

        const sections = await res.json();
        loadedSections = sections.map(s => ({ ...s }));
        editedSections = {};

        document.getElementById('brdSelectorCard').style.display = 'none';
        document.getElementById('actionBar').style.display = '';
        renderSections(sections);
        updateActionButtons();
    }

    function renderSections(sections) {
        const container = document.getElementById('sectionsContainer');

        if (sections.length === 0) {
            container.innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><p class="mt-2">No sections in this BRD.</p></div>';
            return;
        }

        container.innerHTML = `
            <div class="accordion" id="sectionsAccordion">
                ${sections.map((s, i) => `
                    <div class="accordion-item" data-section-id="${s.id}">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#section${i}">
                                <span class="badge bg-secondary me-2">${s.order}</span>
                                ${formatSectionName(s.sectionType)}
                                <span class="badge bg-warning ms-2 dirty-badge" style="display:none;">Modified</span>
                            </button>
                        </h2>
                        <div id="section${i}" class="accordion-collapse collapse" data-bs-parent="#sectionsAccordion">
                            <div class="accordion-body">
                                <div class="d-flex justify-content-end gap-1 mb-2">
                                    <button class="btn btn-sm btn-outline-primary btn-edit" onclick="toggleEdit('${s.id}', ${i})">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </button>
                                    <button class="btn btn-sm btn-success btn-save-one" onclick="saveOneSection('${s.id}', ${i})" style="display:none;">
                                        <i class="bi bi-check-lg me-1"></i>Save
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary btn-cancel-one" onclick="cancelOneEdit('${s.id}', ${i})" style="display:none;">
                                        Cancel
                                    </button>
                                </div>
                                <pre class="bg-light p-3 rounded small section-view" id="view-${i}" style="white-space:pre-wrap">${escapeHtml(s.content)}</pre>
                                <textarea class="form-control font-monospace small section-editor" id="editor-${i}" rows="20" style="display:none; white-space:pre;">${escapeHtml(s.content)}</textarea>
                            </div>
                        </div>
                    </div>
                `).join('')}
            </div>
        `;
    }

    // ── Editing ───────────────────────────────────────────
    function toggleEdit(sectionId, idx) {
        const view = document.getElementById(`view-${idx}`);
        const editor = document.getElementById(`editor-${idx}`);
        const item = document.querySelector(`[data-section-id="${sectionId}"]`);

        view.style.display = 'none';
        editor.style.display = '';
        item.querySelector('.btn-edit').style.display = 'none';
        item.querySelector('.btn-save-one').style.display = '';
        item.querySelector('.btn-cancel-one').style.display = '';

        editor.oninput = () => {
            const original = loadedSections.find(s => s.id === sectionId);
            if (editor.value !== original.content) {
                editedSections[sectionId] = editor.value;
                item.querySelector('.dirty-badge').style.display = '';
            } else {
                delete editedSections[sectionId];
                item.querySelector('.dirty-badge').style.display = 'none';
            }
            updateActionButtons();
        };
    }

    function cancelOneEdit(sectionId, idx) {
        const view = document.getElementById(`view-${idx}`);
        const editor = document.getElementById(`editor-${idx}`);
        const item = document.querySelector(`[data-section-id="${sectionId}"]`);

        const original = loadedSections.find(s => s.id === sectionId);
        editor.value = original.content;
        view.textContent = original.content;
        delete editedSections[sectionId];
        item.querySelector('.dirty-badge').style.display = 'none';

        editor.style.display = 'none';
        view.style.display = '';
        item.querySelector('.btn-edit').style.display = '';
        item.querySelector('.btn-save-one').style.display = 'none';
        item.querySelector('.btn-cancel-one').style.display = 'none';
        updateActionButtons();
    }

    async function saveOneSection(sectionId, idx) {
        const editor = document.getElementById(`editor-${idx}`);
        const res = await fetch(`/api/brd/sections/${sectionId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: editor.value })
        });

        if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            alert('Save failed: ' + (err.error || res.statusText));
            return;
        }

        const orig = loadedSections.find(s => s.id === sectionId);
        if (orig) orig.content = editor.value;
        delete editedSections[sectionId];

        document.getElementById(`view-${idx}`).textContent = editor.value;
        cancelOneEdit(sectionId, idx);
        showToast('Section saved.');
    }

    async function saveAllSections() {
        const ids = Object.keys(editedSections);
        if (ids.length === 0) return;

        document.getElementById('btnSaveAll').disabled = true;
        let saved = 0, failed = 0;

        for (const id of ids) {
            const res = await fetch(`/api/brd/sections/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ content: editedSections[id] })
            });

            if (res.ok) {
                const orig = loadedSections.find(s => s.id === id);
                if (orig) orig.content = editedSections[id];
                delete editedSections[id];
                const item = document.querySelector(`[data-section-id="${id}"]`);
                if (item) item.querySelector('.dirty-badge').style.display = 'none';
                saved++;
            } else {
                failed++;
            }
        }

        showToast(`${saved} section(s) saved.${failed > 0 ? ` ${failed} failed.` : ''}`);
        if (selectedBrdId) await loadSections(selectedBrdId);
    }

    function cancelEdits() {
        if (Object.keys(editedSections).length > 0 && !confirm('Discard all unsaved changes?')) return;
        editedSections = {};
        if (selectedBrdId) loadSections(selectedBrdId);
    }

    async function enrichAllSections() {
        if (!selectedBrdId) return;
        if (!confirm('This will use AI to enrich all draft sections with content generated from uploaded source documents. Continue?')) return;

        const btn = document.getElementById('btnEnrich');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Enriching...';

        try {
            const res = await fetch(`/api/brd/documents/${selectedBrdId}/enrich`, { method: 'POST' });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                alert('Enrichment failed: ' + (err.error || res.statusText));
                return;
            }
            const result = await res.json();
            showToast(`AI enrichment complete: ${result.sectionsEnriched} enriched, ${result.sectionsFailed} failed.`);
            if (selectedBrdId) {
                await loadBrdDocument(selectedBrdId);
            }
        } catch (ex) {
            alert('Enrichment error: ' + ex.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    // ── Expand / Collapse ─────────────────────────────────
    function expandAll() {
        document.querySelectorAll('#sectionsAccordion .accordion-collapse').forEach(el => {
            new bootstrap.Collapse(el, { toggle: false }).show();
        });
    }
    function collapseAll() {
        document.querySelectorAll('#sectionsAccordion .accordion-collapse.show').forEach(el => {
            bootstrap.Collapse.getInstance(el)?.hide();
        });
    }

    // ── Helpers ───────────────────────────────────────────
    function updateActionButtons() {
        const hasDirty = Object.keys(editedSections).length > 0;
        document.getElementById('btnSaveAll').disabled = !hasDirty;
        document.getElementById('btnCancelEdits').disabled = !hasDirty;
    }

    function formatSectionName(type) {
        return type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    function escapeHtml(text) {
        if (!text) return '';
        const d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    function showToast(message) {
        let container = document.getElementById('toastContainer');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toastContainer';
            container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
            container.style.zIndex = 1090;
            document.body.appendChild(container);
        }
        const id = 'toast-' + Date.now();
        container.insertAdjacentHTML('beforeend', `
            <div id="${id}" class="toast align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body"><i class="bi bi-check-circle me-1"></i>${message}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `);
        const toastEl = document.getElementById(id);
        new bootstrap.Toast(toastEl, { delay: 3000 }).show();
        toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
    }

    window.addEventListener('beforeunload', (e) => {
        if (Object.keys(editedSections).length > 0) {
            e.preventDefault();
            e.returnValue = '';
        }
    });

    // ── Workflow Status ───────────────────────────────────
    let currentBrdStatus = 'draft';

    function statusBadgeClass(status) {
        switch (status) {
            case 'draft': return 'bg-secondary';
            case 'enriched': return 'bg-info';
            case 'in_review': return 'bg-warning text-dark';
            case 'approved': return 'bg-success';
            case 'rejected': return 'bg-danger';
            default: return 'bg-secondary';
        }
    }

    function typeBadgeClass(type) {
        const map = {
            'general': 'bg-secondary', 'web_application': 'bg-primary',
            'mobile_application': 'bg-success', 'api_service': 'bg-warning text-dark',
            'data_pipeline': 'bg-danger', 'integration': 'bg-dark'
        };
        return map[type] || 'bg-secondary';
    }

    function formatStatus(status) {
        return (status || 'draft').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    function updateWorkflowBar(status) {
        currentBrdStatus = status;
        const bar = document.getElementById('workflowBar');
        bar.style.display = '';

        const badge = document.getElementById('activeBrdStatus');
        badge.className = `badge ms-1 ${statusBadgeClass(status)}`;
        badge.textContent = formatStatus(status);

        const statusOrder = ['draft', 'enriched', 'in_review', 'approved'];
        const currentIdx = statusOrder.indexOf(status);

        const steps = {
            'stepDraft':    currentIdx >= 0 ? (currentIdx === 0 ? 'bg-primary' : 'bg-primary bg-opacity-50') : 'bg-light text-muted',
            'stepEnriched': currentIdx >= 1 ? (currentIdx === 1 ? 'bg-info' : 'bg-info bg-opacity-50') : 'bg-light text-muted',
            'stepInReview': currentIdx >= 2 ? (currentIdx === 2 ? 'bg-warning text-dark' : 'bg-warning bg-opacity-50') : 'bg-light text-muted',
            'stepApproved': currentIdx >= 3 ? 'bg-success' : 'bg-light text-muted'
        };
        if (status === 'rejected') {
            steps['stepApproved'] = 'bg-danger';
            document.getElementById('stepApproved').textContent = 'Rejected';
        } else {
            document.getElementById('stepApproved').textContent = 'Approved';
        }
        for (const [id, cls] of Object.entries(steps)) {
            document.getElementById(id).className = `badge rounded-pill ${cls}`;
        }

        document.getElementById('btnSubmitReview').style.display = (status === 'draft' || status === 'enriched') ? '' : 'none';
        document.getElementById('btnApprove').style.display = status === 'in_review' ? '' : 'none';
        document.getElementById('btnReject').style.display = status === 'in_review' ? '' : 'none';
        document.getElementById('btnRequestChanges').style.display = status === 'in_review' ? '' : 'none';
    }

    async function submitForReview() {
        if (!selectedBrdId) return;
        if (Object.keys(editedSections).length > 0) {
            if (!confirm('You have unsaved changes. Save them before submitting?')) return;
            await saveAllSections();
        }
        const res = await fetch(`/api/brd/documents/${selectedBrdId}/submit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewer: 'user' })
        });
        const data = await res.json();
        if (res.ok) {
            showToast(data.message);
            updateWorkflowBar('in_review');
        } else {
            alert(data.error || 'Submit failed');
        }
    }

    async function approveBrd() {
        if (!selectedBrdId) return;
        const comment = prompt('Approval comment (optional):');
        const res = await fetch(`/api/brd/documents/${selectedBrdId}/approve`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewer: 'user', comment: comment || null })
        });
        const data = await res.json();
        if (res.ok) {
            showToast(data.message);
            updateWorkflowBar('approved');
            if (data.approvedAt) {
                document.getElementById('approvalInfo').style.display = '';
                document.getElementById('approvalInfo').textContent =
                    `Approved by ${data.approvedBy || 'user'} on ${new Date(data.approvedAt).toLocaleString()}`;
            }
        } else {
            alert(data.error || 'Approval failed');
        }
    }

    async function rejectBrd() {
        if (!selectedBrdId) return;
        const reason = prompt('Rejection reason (required):');
        if (!reason) return;
        const res = await fetch(`/api/brd/documents/${selectedBrdId}/reject`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewer: 'user', reason })
        });
        const data = await res.json();
        if (res.ok) {
            showToast(data.message);
            updateWorkflowBar('rejected');
        } else {
            alert(data.error || 'Rejection failed');
        }
    }

    async function requestChanges() {
        if (!selectedBrdId) return;
        const feedback = prompt('Feedback / changes needed (required):');
        if (!feedback) return;
        const res = await fetch(`/api/brd/documents/${selectedBrdId}/request-changes`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reviewer: 'user', feedback })
        });
        const data = await res.json();
        if (res.ok) {
            showToast(data.message);
            updateWorkflowBar('draft');
        } else {
            alert(data.error || 'Request changes failed');
        }
    }
</script>
}
